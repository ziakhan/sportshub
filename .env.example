# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/youthbasketballhub?schema=public"

# ============================================
# NEXTAUTH AUTHENTICATION
# ============================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# ============================================
# NATIVE AUTH + REALTIME SIDECAR
# Signs 15-min bearer access JWTs (/api/auth/token) and socket tickets.
# Must match AUTH_TOKEN_SECRET on the sidecar (apps/sidecar).
# ============================================
AUTH_TOKEN_SECRET="generate-another-random-secret-here"

# ============================================
# STRIPE PAYMENTS (test mode until launch)
# Without these, online payments answer 503 and offline mode works fully.
# Webhook secret: `stripe listen` locally / dashboard endpoint in prod.
# ============================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# ============================================
# APP CONFIGURATION
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_PLATFORM_DOMAIN="app.youthbasketballhub.com"

# ============================================
# EMAIL (SMTP - use Mailpit for local dev)
# Run: mailpit (Web UI at http://localhost:8025)
# ============================================
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@youthbasketballhub.com"

# ============================================
# FILE STORAGE (Vercel Blob)
# ============================================
BLOB_READ_WRITE_TOKEN="vercel_blob_xxx"

# ============================================
# AI RECAPS (optional)
# Without ANTHROPIC_API_KEY, game recaps use the deterministic template.
# RECAP_AI_MODEL overrides the default model (claude-opus-4-8).
# ============================================
ANTHROPIC_API_KEY=""
RECAP_AI_MODEL=""

# ============================================
# SCHEDULING
# APP_TIMEZONE: wall-clock timezone for practice/game expansion
# (default America/Toronto).
# CRON_SECRET: bearer token required by /api/cron/* routes
# (expire-offers, charge-due, payment-reminders).
# ============================================
APP_TIMEZONE="America/Toronto"
CRON_SECRET="generate-a-random-secret-here"

# ============================================
# GOOGLE PLACES (venue autocomplete)
# NEXT_PUBLIC_ = build-time; changing it on Vercel needs a redeploy.
# ============================================
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=""

# ============================================
# MONITORING (optional)
# ============================================
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
