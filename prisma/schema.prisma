// Youth Basketball Hub - Complete Prisma Schema
// Includes all MVP models with recommended enhancements

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin", "darwin-arm64", "linux-musl-openssl-3.0.x", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE ENTITIES
// ============================================

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String
  firstName    String?
  lastName     String?
  phoneNumber  String?
  avatarUrl    String?
  city         String?
  state        String?
  country      String  @default("CA") // ISO 3166-1 alpha-2

  // Soft Delete (Recommended Addition)
  status    UserStatus @default(ACTIVE)
  deletedAt DateTime?

  // Onboarding
  onboardedAt DateTime?

  // Relationships
  roles               UserRole[]
  players             Player[]            @relation("ParentPlayers")
  tryoutSignups       TryoutSignup[]
  paymentsAsPayer     Payment[]           @relation("PayerPayments")
  paymentsAsPayee     Payment[]           @relation("PayeePayments")
  auditLogs           AuditLog[]
  reviews             Review[]            @relation("ReviewsWritten")
  reviewsReceived     Review[]            @relation("ReviewsReceived")
  announcements       Announcement[]
  sentInvitations     StaffInvitation[]   @relation("SentInvitations")
  receivedInvitations StaffInvitation[]   @relation("ReceivedInvitations")
  notifications       Notification[]
  clubClaims          ClubClaim[]
  houseLeagueSignups  HouseLeagueSignup[]
  campSignups         CampSignup[]
  tournaments         Tournament[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role Role

  // Scope (nullable based on role)
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  leagueId String?
  league   League? @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  gameId String? // For temporary scorekeeper role
  game   Game?   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  designation String? // "HeadCoach", "AssistantCoach" — for Coach roles on a team
  expiresAt   DateTime? // For temporary roles

  createdAt DateTime @default(now())

  @@unique([userId, role, tenantId, teamId, leagueId, gameId])
  @@index([userId])
  @@index([tenantId])
  @@index([teamId])
  @@index([leagueId])
}

enum Role {
  ClubOwner
  ClubManager
  Staff
  TeamManager
  Scorekeeper
  LeagueOwner
  LeagueManager
  Parent
  Player
  Referee
  PlatformAdmin
}

// ============================================
// MULTI-TENANCY
// ============================================

model Tenant {
  id           String  @id @default(uuid())
  slug         String  @unique
  name         String
  description  String? @db.Text
  phoneNumber  String?
  contactEmail String?
  address      String?
  city         String?
  state        String?
  zipCode      String?
  country      String  @default("US") // ISO 3166-1 alpha-2
  currency     String  @default("CAD") // ISO 4217
  website      String?
  customDomain String? @unique

  // Timezone (Recommended Addition)
  timezone String @default("America/New_York")

  // Stripe
  stripeAccountId     String? @unique
  stripeAccountStatus String? // active, pending, restricted

  // Subscription
  plan          TenantPlan   @default(FREE)
  planExpiresAt DateTime?
  status        TenantStatus @default(ACTIVE)

  // Relationships
  branding         TenantBranding?
  features         TenantFeatures?
  teams            Team[]
  staff            UserRole[]
  tryouts          Tryout[]
  practices        Practice[]
  venues           Venue[]
  announcements    Announcement[]
  payments         Payment[]         @relation("TenantPayments")
  reviews          Review[]
  staffInvitations StaffInvitation[]
  clubClaims       ClubClaim[]
  houseLeagues     HouseLeague[]
  camps            Camp[]
  offerTemplates   OfferTemplate[]
  tournaments      Tournament[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([customDomain])
}

enum TenantPlan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  UNCLAIMED
}

model TenantBranding {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  logoUrl        String?
  faviconUrl     String?
  primaryColor   String  @default("#1a73e8")
  secondaryColor String  @default("#34a853")
  accentColor    String  @default("#fbbc04")
  fontFamily     String  @default("Inter")
  customCss      String? @db.Text

  emailLogoUrl String?
  emailFooter  String? @db.Text

  updatedAt DateTime @updatedAt
}

model TenantFeatures {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  enableTournaments Boolean @default(false)
  enableReviews     Boolean @default(true)
  enableChat        Boolean @default(false)
  enableAnalytics   Boolean @default(false)

  maxTeams  Int @default(10)
  maxStaff  Int @default(5)
  maxVenues Int @default(3)
}

// ============================================
// TEAMS & PLAYERS
// ============================================

model Team {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  ageGroup    String // U10, U12, U14, etc.
  gender      Gender?
  season      String? // "Spring 2026"
  description String? @db.Text

  // Relationships
  players           TeamPlayer[]
  staff             UserRole[]
  seasonSubmissions TeamSubmission[]
  homeGames         Game[]           @relation("HomeTeam")
  awayGames         Game[]           @relation("AwayTeam")
  practices         Practice[]
  announcements     Announcement[]
  offers            Offer[]
  offerTemplates    OfferTemplate[]
  tryouts           Tryout[]
  tournamentEntries TournamentTeam[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([ageGroup])
}

enum Gender {
  MALE
  FEMALE
  COED
}

model Player {
  id String @id @default(uuid())

  // Personal Info
  firstName    String
  lastName     String
  dateOfBirth  DateTime
  gender       Gender
  jerseyNumber String?
  height       String? // e.g. "5'6"
  weight       Int? // in pounds
  position     String? // e.g. "Point Guard", "Center"

  // COPPA Compliance (Recommended Addition)
  isMinor              Boolean   @default(false) // Age < 13
  parentalConsentGiven Boolean? // Required if isMinor = true
  consentGivenAt       DateTime?
  canLogin             Boolean   @default(false) // Only true if 13+

  // Parent/Guardian
  parentId String
  parent   User   @relation("ParentPlayers", fields: [parentId], references: [id], onDelete: Cascade)

  // Relationships
  teams               TeamPlayer[]
  stats               PlayerStat[]
  offers              Offer[]
  houseLeagueSignups  HouseLeagueSignup[]
  campSignups         CampSignup[]
  seasonRosterEntries SeasonRosterPlayer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([isMinor])
}

model TeamPlayer {
  id     String @id @default(uuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  jerseyNumber  Int?
  uniformSize   String? // YS, YM, YL, AS, AM, AL, AXL
  shoeSize      String? // e.g. "7", "8.5"
  tracksuitSize String? // YS, YM, YL, AS, AM, AL, AXL

  status   TeamPlayerStatus @default(ACTIVE)
  joinedAt DateTime         @default(now())
  leftAt   DateTime?

  @@unique([teamId, playerId])
  @@index([teamId])
  @@index([playerId])
}

enum TeamPlayerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ============================================
// REFEREE PROFILES (Recommended Addition)
// ============================================

model RefereeProfile {
  id     String @id @default(uuid())
  userId String @unique

  // Certifications
  certificationLevel  String? // "Level 1", "Level 2", etc.
  certificationExpiry DateTime?

  // Availability
  availableRegions String[] // ["California", "Nevada"]

  // Fee
  standardFee Decimal @db.Decimal(10, 2)

  // Stripe Connect
  stripeAccountId     String? @unique
  stripeAccountStatus String?

  // Stats
  gamesRefereed Int      @default(0)
  averageRating Decimal? @db.Decimal(3, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ============================================
// TRYOUTS & OFFERS
// ============================================

model Tryout {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  title       String
  description String? @db.Text
  ageGroup    String
  gender      Gender?

  location    String
  scheduledAt DateTime
  duration    Int? // minutes

  fee             Decimal @db.Decimal(10, 2)
  maxParticipants Int?

  isPublished Boolean @default(false)
  isPublic    Boolean @default(true)

  // Relationships
  signups TryoutSignup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([teamId])
  @@index([scheduledAt])
  @@index([isPublished, isPublic])
}

model TryoutSignup {
  id       String @id @default(uuid())
  tryoutId String
  tryout   Tryout @relation(fields: [tryoutId], references: [id], onDelete: Cascade)

  userId String // Parent
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  playerName   String
  playerAge    Int
  playerGender Gender

  status    TryoutSignupStatus @default(PENDING)
  paymentId String?            @unique
  payment   Payment?           @relation(fields: [paymentId], references: [id])

  notes String? @db.Text

  // Relationships
  offers Offer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tryoutId, userId, playerName])
  @@index([tryoutId])
  @@index([userId])
}

enum TryoutSignupStatus {
  PENDING
  PAID
  CONFIRMED
  CANCELLED
  OFFERED
}

model OfferTemplate {
  id       String  @id @default(uuid())
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Legacy: was team-scoped, now club-scoped. Kept nullable for existing data.
  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  name String // e.g. "Standard Package", "Premium Package"

  seasonFee        Decimal @db.Decimal(10, 2)
  installments     Int     @default(1)
  practiceSessions Int     @default(0)

  // Included items
  includesBall      Boolean @default(false) // basketball
  includesBag       Boolean @default(false) // equipment bag
  includesShoes     Boolean @default(false)
  includesUniform   Boolean @default(false) // shirt + shorts
  includesTracksuit Boolean @default(false)

  isActive Boolean @default(true)

  offers Offer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Offer {
  id     String @id @default(uuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  tryoutSignupId String?
  tryoutSignup   TryoutSignup? @relation(fields: [tryoutSignupId], references: [id])

  templateId String?
  template   OfferTemplate? @relation(fields: [templateId], references: [id])

  status OfferStatus @default(PENDING)

  // Offer details (copied from template, tweakable per offer)
  seasonFee        Decimal @db.Decimal(10, 2)
  installments     Int     @default(1)
  practiceSessions Int     @default(0)

  // Included items
  includesBall      Boolean @default(false)
  includesBag       Boolean @default(false)
  includesShoes     Boolean @default(false)
  includesUniform   Boolean @default(false)
  includesTracksuit Boolean @default(false)

  message   String?  @db.Text
  expiresAt DateTime

  // Filled on acceptance by parent/player
  uniformSize   String? // YS, YM, YL, AS, AM, AL, AXL
  shoeSize      String? // e.g. "7", "8.5"
  tracksuitSize String? // YS, YM, YL, AS, AM, AL, AXL
  jerseyPref1   Int? // First choice jersey number
  jerseyPref2   Int? // Second choice jersey number
  jerseyPref3   Int? // Third choice jersey number

  respondedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId])
  @@index([playerId])
  @@index([tryoutSignupId])
  @@index([templateId])
  @@index([status])
}

enum OfferStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

// ============================================
// LEAGUES, SEASONS & GAMES
// ============================================

model League {
  id              String  @id @default(uuid())
  name            String
  description     String? @db.Text
  ownerId         String
  currency        String  @default("CAD")
  stripeAccountId String? @unique

  seasons Season[]
  staff   UserRole[]
  reviews Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Season {
  id       String @id @default(uuid())
  leagueId String
  league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  label String
  type  SeasonType @default(FALL_WINTER)

  startDate            DateTime?
  endDate              DateTime?
  registrationDeadline DateTime?
  ageGroupCutoffDate   DateTime?

  teamFee  Decimal? @db.Decimal(10, 2)
  currency String   @default("CAD")

  gameSlotMinutes     Int    @default(90)
  gameLengthMinutes   Int    @default(40)
  gamePeriods         String @default("HALVES")
  periodLengthMinutes Int?

  gamesGuaranteed         Int?
  targetGamesPerSession   Int?
  idealGamesPerDayPerTeam Int  @default(1)

  defaultVenueOpenTime  String @default("09:00")
  defaultVenueCloseTime String @default("20:00")

  schedulingPhilosophy         SchedulingPhilosophy @default(FAMILY_FRIENDLY)
  allowCrossDivisionScheduling Boolean              @default(false)

  tiebreakerOrder     String[]  @default([])
  tiebreakersLockedAt DateTime?

  status SeasonStatus @default(DRAFT)

  playoffFormat String?
  playoffTeams  Int?

  divisions        Division[]
  teamSubmissions  TeamSubmission[]
  sessions         SeasonSession[]
  seasonVenues     SeasonVenue[]
  rosters          SeasonRoster[]
  games            Game[]
  schedulingGroups SchedulingGroup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leagueId])
  @@index([status])
}

enum SeasonStatus {
  DRAFT
  REGISTRATION
  REGISTRATION_CLOSED
  FINALIZED
  IN_PROGRESS
  COMPLETED
}

enum SeasonType {
  FALL_WINTER
  SUMMER
  SPRING
  CUSTOM
}

enum SchedulingPhilosophy {
  FAMILY_FRIENDLY
  SPREAD_DAYS
}

model Division {
  id       String @id @default(uuid())
  seasonId String
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  name     String
  ageGroup String
  gender   Gender?
  tier     Int     @default(1)
  maxTeams Int?

  teamSubmissions  TeamSubmission[]
  schedulingGroups SchedulingGroupDivision[]

  @@index([seasonId])
}

model TeamSubmission {
  id       String @id @default(uuid())
  seasonId String
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  divisionId String?
  division   Division? @relation(fields: [divisionId], references: [id])

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  status          TeamSubmissionStatus      @default(PENDING)
  paymentStatus   RegistrationPaymentStatus @default(UNPAID)
  registrationFee Decimal?                  @db.Decimal(10, 2)
  paymentId       String?                   @unique
  payment         Payment?                  @relation(fields: [paymentId], references: [id])

  roster    SeasonRoster?
  blackouts SeasonTeamBlackout[]

  createdAt DateTime @default(now())

  @@unique([seasonId, teamId])
  @@index([seasonId])
  @@index([teamId])
}

enum TeamSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

enum RegistrationPaymentStatus {
  UNPAID
  PAID_MANUAL
  PAID_STRIPE
  WAIVED
}

model SeasonRoster {
  id       String @id @default(uuid())
  seasonId String
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  teamSubmissionId String         @unique
  teamSubmission   TeamSubmission @relation(fields: [teamSubmissionId], references: [id], onDelete: Cascade)

  isLocked    Boolean   @default(false)
  submittedAt DateTime?
  lockedAt    DateTime?

  players SeasonRosterPlayer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([seasonId])
}

model SeasonRosterPlayer {
  id       String       @id @default(uuid())
  rosterId String
  roster   SeasonRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  playerId String
  player   Player @relation(fields: [playerId], references: [id])

  jerseyNumber Int?
  position     String?

  createdAt DateTime @default(now())

  @@unique([rosterId, playerId])
  @@index([rosterId])
  @@index([playerId])
}

model SeasonSession {
  id       String @id @default(uuid())
  seasonId String
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  label              String?
  phase              SessionPhase @default(REGULAR)
  targetGamesPerTeam Int?

  days  SeasonSessionDay[]
  games Game[]

  createdAt DateTime @default(now())

  @@index([seasonId])
}

enum SessionPhase {
  REGULAR
  PLAYOFF
}

model SeasonSessionDay {
  id        String        @id @default(uuid())
  sessionId String
  session   SeasonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  date DateTime

  dayVenues SeasonSessionDayVenue[]
  games     Game[]

  @@index([sessionId])
  @@index([date])
}

model SeasonSessionDayVenue {
  id    String           @id @default(uuid())
  dayId String
  day   SeasonSessionDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id])

  startTime String?
  endTime   String?

  courts SeasonSessionDayVenueCourt[]
  games  Game[]

  @@index([dayId])
  @@index([venueId])
}

model SeasonSessionDayVenueCourt {
  id         String                @id @default(uuid())
  dayVenueId String
  dayVenue   SeasonSessionDayVenue @relation(fields: [dayVenueId], references: [id], onDelete: Cascade)

  courtId String
  court   Court  @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@unique([dayVenueId, courtId])
  @@index([dayVenueId])
  @@index([courtId])
}

model SeasonVenue {
  id       String @id @default(uuid())
  seasonId String
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id])

  isPrimary       Boolean @default(false)
  courtsAvailable Int?

  @@unique([seasonId, venueId])
  @@index([seasonId])
}

model SchedulingGroup {
  id       String @id @default(uuid())
  seasonId String
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  name      String
  divisions SchedulingGroupDivision[]

  createdAt DateTime @default(now())

  @@index([seasonId])
}

model SchedulingGroupDivision {
  schedulingGroupId String
  schedulingGroup   SchedulingGroup @relation(fields: [schedulingGroupId], references: [id], onDelete: Cascade)

  divisionId String
  division   Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)

  @@id([schedulingGroupId, divisionId])
  @@index([divisionId])
}

model SeasonTeamBlackout {
  id               String         @id @default(uuid())
  teamSubmissionId String
  teamSubmission   TeamSubmission @relation(fields: [teamSubmissionId], references: [id], onDelete: Cascade)

  date      DateTime
  startTime String?
  endTime   String?
  reason    String?

  createdAt DateTime @default(now())

  @@index([teamSubmissionId])
}

model Game {
  id String @id @default(uuid())

  seasonId String?
  season   Season? @relation(fields: [seasonId], references: [id])

  phase SessionPhase?

  sessionId String?
  session   SeasonSession? @relation(fields: [sessionId], references: [id])

  dayId String?
  day   SeasonSessionDay? @relation(fields: [dayId], references: [id])

  dayVenueId String?
  dayVenue   SeasonSessionDayVenue? @relation(fields: [dayVenueId], references: [id])

  courtId String?
  court   Court?  @relation(fields: [courtId], references: [id])

  homeTeamId String
  homeTeam   Team   @relation("HomeTeam", fields: [homeTeamId], references: [id])

  awayTeamId String
  awayTeam   Team   @relation("AwayTeam", fields: [awayTeamId], references: [id])

  venueId String?
  venue   Venue?  @relation(fields: [venueId], references: [id])

  scheduledAt DateTime
  duration    Int        @default(90)
  status      GameStatus @default(SCHEDULED)

  homeScore Int?
  awayScore Int?

  isLocked    Boolean @default(false)
  defaultedBy String?

  events       GameEvent[]
  stats        PlayerStat[]
  scorekeepers UserRole[]

  finalizedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([seasonId])
  @@index([sessionId])
  @@index([dayId])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([scheduledAt])
  @@index([status])
}

enum GameStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
  POSTPONED
  DEFAULTED
}

model GameEvent {
  id     String @id @default(uuid())
  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  eventType GameEventType
  teamId    String // Team that scored/fouled
  playerId  String? // Player involved

  points    Int? // For SCORE events
  quarter   Int? // 1-4
  timestamp DateTime @default(now())

  metadata Json? // Additional event data

  @@index([gameId])
  @@index([teamId])
  @@index([playerId])
}

enum GameEventType {
  SCORE_2PT
  SCORE_3PT
  SCORE_FT
  REBOUND
  ASSIST
  STEAL
  BLOCK
  TURNOVER
  FOUL
  TIMEOUT
  SUBSTITUTION
}

model PlayerStat {
  id     String @id @default(uuid())
  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  // Stats (Auto-calculated from GameEvents)
  points    Int @default(0)
  rebounds  Int @default(0)
  assists   Int @default(0)
  steals    Int @default(0)
  blocks    Int @default(0)
  turnovers Int @default(0)
  fouls     Int @default(0)

  minutesPlayed Int?

  @@unique([gameId, playerId])
  @@index([gameId])
  @@index([playerId])
}

// ============================================
// VENUES & PRACTICES
// ============================================

model Venue {
  id       String  @id @default(uuid())
  tenantId String? // Optional — venues are global
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  name        String
  address     String
  city        String
  state       String
  zipCode     String?
  country     String  @default("CA")
  phoneNumber String?

  // Google Places
  placeId   String? @unique // Google Place ID for dedup
  latitude  Float?
  longitude Float?

  capacity Int?
  courts   Int? // Legacy count — courts[] is the source of truth going forward
  notes    String? @db.Text

  games            Game[]
  practices        Practice[]
  seasonVenues     SeasonVenue[]
  dayVenues        SeasonSessionDayVenue[]
  courtList        Court[]
  venueHours       VenueHours[]
  tournamentVenues TournamentVenue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([city])
  @@index([name])
}

model Court {
  id      String @id @default(uuid())
  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  name         String
  displayOrder Int    @default(0)

  dayVenueCourts SeasonSessionDayVenueCourt[]
  games          Game[]

  createdAt DateTime @default(now())

  @@index([venueId])
}

model VenueHours {
  id      String @id @default(uuid())
  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  dayOfWeek Int // 0 = Sunday ... 6 = Saturday
  openTime  String? // null = closed that day
  closeTime String?

  @@unique([venueId, dayOfWeek])
  @@index([venueId])
}

model Practice {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  venueId String?
  venue   Venue?  @relation(fields: [venueId], references: [id])

  scheduledAt DateTime
  duration    Int // minutes

  notes  String?        @db.Text
  status PracticeStatus @default(SCHEDULED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([teamId])
  @@index([scheduledAt])
}

enum PracticeStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

// ============================================
// PAYMENTS (Enhanced with Installments)
// ============================================

model Payment {
  id String @id @default(uuid())

  // Stripe
  stripePaymentIntentId String? @unique
  stripeChargeId        String? @unique

  // Parties
  payerId String
  payer   User   @relation("PayerPayments", fields: [payerId], references: [id])

  payeeId String? // Club/League owner
  payee   User?   @relation("PayeePayments", fields: [payeeId], references: [id])

  tenantId String? // If club payment
  tenant   Tenant? @relation("TenantPayments", fields: [tenantId], references: [id])

  // Payment Details
  amount      Decimal  @db.Decimal(10, 2)
  currency    String   @default("usd")
  platformFee Decimal? @db.Decimal(10, 2)

  status PaymentStatus @default(PENDING)

  // Installments (Recommended Addition)
  dueDate           DateTime? // For installment payments
  installmentNumber Int? // 1, 2, 3, 4
  relatedOfferId    String? // Link installments together

  // Context
  paymentType PaymentType
  description String?

  // Relationships
  tryoutSignup   TryoutSignup?
  teamSubmission TeamSubmission?

  // Refund
  refundedAt   DateTime?
  refundAmount Decimal?  @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([payerId])
  @@index([payeeId])
  @@index([tenantId])
  @@index([status])
  @@index([paymentType])
  @@index([dueDate])
  @@index([relatedOfferId])
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  DISPUTED
}

enum PaymentType {
  TRYOUT_FEE
  SEASON_FEE
  LEAGUE_FEE
  TOURNAMENT_FEE
  REFEREE_FEE
  OTHER
}

// ============================================
// COMMUNICATIONS
// ============================================

model Announcement {
  id       String  @id @default(uuid())
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  title   String
  content String @db.Text

  isPinned Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([teamId])
  @@index([createdAt])
}

// ============================================
// REVIEWS & RATINGS (v1+)
// ============================================

model Review {
  id String @id @default(uuid())

  reviewerId String
  reviewer   User   @relation("ReviewsWritten", fields: [reviewerId], references: [id])

  // Target (one of these)
  tenantId String? // Review of club
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  leagueId String? // Review of league
  league   League? @relation(fields: [leagueId], references: [id])

  revieweeId String? // Review of a specific user (coach/staff/referee)
  reviewee   User?   @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  // Content
  rating  Int // 1-5
  title   String?
  content String? @db.Text

  status ReviewStatus @default(PUBLISHED)

  // Moderation
  flaggedAt      DateTime?
  moderatedAt    DateTime?
  moderatorNotes String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([leagueId])
  @@index([reviewerId])
  @@index([revieweeId])
  @@index([status])
}

enum ReviewStatus {
  PUBLISHED
  FLAGGED
  REMOVED
}

// ============================================
// STAFF INVITATIONS & NOTIFICATIONS
// ============================================

model StaffInvitation {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Who sent it
  invitedById String
  invitedBy   User   @relation("SentInvitations", fields: [invitedById], references: [id])

  // Who it's for
  invitedUserId String?
  invitedUser   User?   @relation("ReceivedInvitations", fields: [invitedUserId], references: [id])
  invitedEmail  String

  role        Role
  teamId      String?
  designation String? // "HeadCoach", "AssistantCoach" — carried through on accept
  message     String? @db.Text

  type   InvitationType
  status InvitationStatus @default(PENDING)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  respondedAt DateTime?

  @@index([tenantId])
  @@index([invitedUserId])
  @@index([invitedEmail])
  @@index([status])
}

enum InvitationType {
  INVITE
  REQUEST
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    String
  title   String
  message String  @db.Text
  link    String?

  isRead Boolean @default(false)

  referenceId   String?
  referenceType String?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ============================================
// AUDIT & LOGGING
// ============================================

model AuditLog {
  id String @id @default(uuid())

  userId   String
  user     User   @relation(fields: [userId], references: [id])
  userRole Role

  action     String // CREATE, UPDATE, DELETE, etc.
  resource   String // Team, Payment, etc.
  resourceId String

  tenantId  String?
  ipAddress String
  userAgent String

  changes  Json?
  metadata Json?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([tenantId, createdAt])
  @@index([resource, resourceId])
}

// ============================================
// HOUSE LEAGUES (club programs)
// ============================================

model HouseLeague {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String? @db.Text
  details     String? @db.Text // What's included, program details

  ageGroups String // Comma-separated: "U8,U10,U12"
  gender    Gender?
  season    String? // "Fall 2026", "Winter 2026-27"

  // Schedule
  startDate  DateTime
  endDate    DateTime
  daysOfWeek String // "Saturday" or "Monday,Wednesday"
  startTime  String // "10:00"
  endTime    String // "12:00"
  location   String

  // Pricing
  fee Decimal @db.Decimal(10, 2)

  // Capacity
  maxParticipants Int?

  // What's included
  includesUniform Boolean @default(false)
  includesJersey  Boolean @default(false)
  includesBall    Boolean @default(false)
  includesMedal   Boolean @default(false)

  isPublished Boolean @default(false)

  // Relationships
  signups HouseLeagueSignup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([isPublished])
  @@index([startDate])
}

model HouseLeagueSignup {
  id            String      @id @default(uuid())
  houseLeagueId String
  houseLeague   HouseLeague @relation(fields: [houseLeagueId], references: [id], onDelete: Cascade)

  userId String // Parent
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  status HouseLeagueSignupStatus @default(REGISTERED)

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([houseLeagueId, playerId]) // One signup per player per league
  @@index([houseLeagueId])
  @@index([userId])
  @@index([playerId])
}

enum HouseLeagueSignupStatus {
  REGISTERED
  CONFIRMED
  WAITLISTED
  CANCELLED
}

// ============================================
// CAMPS (March break, holiday, summer, multi-week)
// ============================================

model Camp {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String? @db.Text
  details     String? @db.Text // What's included, daily activities, etc.

  campType CampType
  ageGroup String
  gender   Gender?

  // Dates
  startDate      DateTime
  endDate        DateTime
  dailyStartTime String // "09:00"
  dailyEndTime   String // "16:00"
  location       String

  // Multi-week pricing
  numberOfWeeks Int      @default(1)
  weeklyFee     Decimal  @db.Decimal(10, 2) // Price per single week
  fullCampFee   Decimal? @db.Decimal(10, 2) // Discounted price for all weeks

  maxParticipants Int?

  // What's included
  includesLunch  Boolean @default(false)
  includesSnacks Boolean @default(false)
  includesJersey Boolean @default(false)
  includesBall   Boolean @default(false)

  isPublished Boolean @default(false)

  signups CampSignup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([campType])
  @@index([isPublished])
  @@index([startDate])
}

enum CampType {
  MARCH_BREAK
  HOLIDAY
  SUMMER
  WEEKLY
}

model CampSignup {
  id     String @id @default(uuid())
  campId String
  camp   Camp   @relation(fields: [campId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  weeksSelected Int     @default(1)
  totalFee      Decimal @db.Decimal(10, 2)

  status CampSignupStatus @default(REGISTERED)
  notes  String?          @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campId, playerId])
  @@index([campId])
  @@index([userId])
  @@index([playerId])
}

enum CampSignupStatus {
  REGISTERED
  CONFIRMED
  WAITLISTED
  CANCELLED
}

// ============================================
// PLATFORM SETTINGS (singleton)
// ============================================

model PlatformSettings {
  id               String   @id @default("default")
  enabledCountries String[] // ISO codes: ["US", "CA"]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ============================================
// CLUB CLAIMS (for unclaimed clubs)
// ============================================

model ClubClaim {
  id String @id @default(uuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status ClaimStatus @default(PENDING)

  // Verification
  verificationCode   String? // 6-digit code sent to club email
  verificationSentAt DateTime?
  verifiedAt         DateTime?

  message String? @db.Text // Optional message from claimant

  reviewedById String? // Admin who approved/rejected
  reviewNote   String?   @db.Text
  reviewedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId]) // One claim per user per club
  @@index([tenantId])
  @@index([userId])
  @@index([status])
}

enum ClaimStatus {
  PENDING
  EMAIL_SENT
  EMAIL_VERIFIED
  APPROVED
  REJECTED
}

// ============================================
// TOURNAMENTS (weekend / short-format events)
// ============================================

model Tournament {
  id          String  @id @default(uuid())
  name        String
  description String? @db.Text

  // Owner (the user who created it — club owner or league owner)
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  // Optional club association (null if created by a league owner)
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Location
  city    String
  state   String?
  country String  @default("CA")

  // Dates
  startDate            DateTime
  endDate              DateTime
  registrationDeadline DateTime?

  // Pricing
  teamFee  Decimal @db.Decimal(10, 2)
  currency String  @default("CAD")

  // Tournament details
  gamesGuaranteed   Int    @default(3)
  gameSlotMinutes   Int    @default(60)
  gameLengthMinutes Int    @default(40)
  gamePeriods       String @default("HALVES") // "HALVES" or "QUARTERS"

  // Playoffs
  playoffFormat String? // "SINGLE_ELIMINATION", "DOUBLE_ELIMINATION", "ROUND_ROBIN"

  // Status
  status TournamentStatus @default(DRAFT)

  // Relationships
  divisions TournamentDivision[]
  teams     TournamentTeam[]
  venues    TournamentVenue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([ownerId])
  @@index([status])
  @@index([startDate])
}

enum TournamentStatus {
  DRAFT
  REGISTRATION
  REGISTRATION_CLOSED
  FINALIZED
  IN_PROGRESS
  COMPLETED
}

model TournamentDivision {
  id           String     @id @default(uuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  name     String // "U12 Boys"
  ageGroup String // "U12"
  gender   Gender?
  maxTeams Int? // Cap per division

  teams TournamentTeam[]

  @@index([tournamentId])
}

model TournamentTeam {
  id           String     @id @default(uuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  divisionId String?
  division   TournamentDivision? @relation(fields: [divisionId], references: [id])

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  status          TournamentTeamStatus @default(PENDING)
  registrationFee Decimal?             @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  @@unique([tournamentId, teamId])
  @@index([tournamentId])
  @@index([teamId])
}

enum TournamentTeamStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

model TournamentVenue {
  id           String     @id @default(uuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id])

  isPrimary Boolean @default(false)

  @@unique([tournamentId, venueId])
  @@index([tournamentId])
}
