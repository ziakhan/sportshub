// Youth Basketball Hub - Complete Prisma Schema
// Includes all MVP models with recommended enhancements

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin", "darwin-arm64", "linux-musl-openssl-3.0.x", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE ENTITIES
// ============================================

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String
  firstName    String?
  lastName     String?
  phoneNumber  String?
  avatarUrl    String?
  city         String?
  state        String?
  country      String  @default("CA") // ISO 3166-1 alpha-2

  // Soft Delete (Recommended Addition)
  status    UserStatus @default(ACTIVE)
  deletedAt DateTime?

  // Onboarding
  onboardedAt DateTime?

  // Payments — the user's Stripe Customer (platform account). Cards live in
  // Stripe's vault, referenced by this id; we never store card data.
  stripeCustomerId String? @unique

  // Personal iCal feed token (/api/calendar/[token]) — practices + games
  // for every team the user belongs to; minted on first "add to calendar"
  calendarToken String? @unique

  // Push quiet hours (M3) — "HH:MM" wall time in APP_TIMEZONE; the window
  // may wrap midnight (22:00 → 08:00). Null = no quiet hours.
  pushQuietStart String?
  pushQuietEnd   String?

  // Relationships
  roles               UserRole[]
  players             Player[]            @relation("ParentPlayers")
  tryoutSignups       TryoutSignup[]
  rsvpResponses       EventRsvp[]         @relation("RsvpResponses")
  programAssignments  ProgramStaff[]      @relation("ProgramAssignments")
  paymentsAsPayer     Payment[]           @relation("PayerPayments")
  paymentsAsPayee     Payment[]           @relation("PayeePayments")
  paymentsRecorded    Payment[]           @relation("RecordedPayments")
  obligations         PaymentObligation[] @relation("UserObligations")
  auditLogs           AuditLog[]
  reviews             Review[]            @relation("ReviewsWritten")
  reviewsReceived     Review[]            @relation("ReviewsReceived")
  announcements       Announcement[]
  sentInvitations     StaffInvitation[]   @relation("SentInvitations")
  receivedInvitations StaffInvitation[]   @relation("ReceivedInvitations")
  sentPlayerInvitations     PlayerInvitation[] @relation("SentPlayerInvitations")
  receivedPlayerInvitations PlayerInvitation[] @relation("ReceivedPlayerInvitations")
  notifications       Notification[]
  clubClaims          ClubClaim[]
  houseLeagueSignups  HouseLeagueSignup[]
  campSignups         CampSignup[]
  tournaments         Tournament[]
  posts               Post[]
  follows             Follow[]
  teamMessages        TeamMessage[]       @relation("TeamMessagesSent")
  teamChatReads       TeamChatRead[]      @relation("TeamChatReads")
  pollsCreated        Poll[]              @relation("PollsCreated")
  teamEventsCreated   TeamEvent[]         @relation("TeamEventsCreated")
  connectedCustomers  ConnectedCustomer[] @relation("ConnectedCustomers")
  pollVotes           PollVote[]          @relation("PollVotes")
  rosterChangeRequests    RosterChangeRequest[] @relation("RosterChangeRequests")
  rosterChangeResolutions RosterChangeRequest[] @relation("RosterChangeResolutions")
  leagueRefereePools      LeagueReferee[]         @relation("LeagueReferees")
  refereeAvailabilities   RefereeAvailability[]   @relation("RefereeAvailabilities")
  targetedRefereeRequests RefereeSessionRequest[] @relation("TargetedRefereeRequests")
  acceptedRefereeRequests RefereeSessionRequest[] @relation("AcceptedRefereeRequests")
  refreshTokens           RefreshToken[]          @relation("UserRefreshTokens")
  devices                 Device[]                @relation("UserDevices")
  submissionRequestsMade    TeamSubmissionRequest[] @relation("SubmissionRequestsMade")
  submissionRequestsDecided TeamSubmissionRequest[] @relation("SubmissionRequestsDecided")
  messageReactions          MessageReaction[]       @relation("MessageReactions")
  chatMutes                 ChatMute[]              @relation("ChatMutes")
  conversationParticipants  ConversationParticipant[] @relation("ConversationParticipants")
  directMessagesSent        DirectMessage[]         @relation("DirectMessagesSent")
  scoreInvitesCreated       GameScoreInvite[]       @relation("ScoreInvitesCreated")
  loginTokens               LoginToken[]            @relation("UserLoginTokens")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  refereeProfile RefereeProfile?
  reviewInvites ReviewInvite[] @relation("ReviewInvites")
  withdrawalRequestsMade    WithdrawalRequest[] @relation("WithdrawalRequestsMade")
  withdrawalRequestsDecided WithdrawalRequest[] @relation("WithdrawalRequestsDecided")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

// Native-app push devices (M3, docs/roadmap/native-app-execution-plan.md).
// One row per push token; token changes create new rows, sign-out and
// Expo DeviceNotRegistered receipts set revokedAt. `provider` allows the
// later Expo→FCM-direct swap without a schema change.
model Device {
  id         String         @id @default(uuid())
  userId     String
  user       User           @relation("UserDevices", fields: [userId], references: [id], onDelete: Cascade)
  platform   DevicePlatform
  provider   PushProvider   @default(EXPO)
  token      String         @unique
  appVersion String?
  lastSeenAt DateTime       @default(now())
  revokedAt  DateTime?
  createdAt  DateTime       @default(now())

  @@index([userId])
}

enum DevicePlatform {
  IOS
  ANDROID
}

enum PushProvider {
  EXPO
  FCM
}

// Native-app bearer auth (M2, docs/roadmap/native-app-execution-plan.md).
// The opaque refresh token is only ever stored hashed. familyId is the
// rotation lineage: each /api/auth/refresh revokes the presented row and
// issues a new one in the same family, so presenting a rotated-out token
// signals theft and revokes the entire family.
model RefreshToken {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation("UserRefreshTokens", fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique // sha256 hex of the opaque token
  familyId    String // constant across rotations of one device login
  deviceLabel String? // e.g. "Pixel 8" — for a future sessions/devices UI
  expiresAt   DateTime // 60d, sliding on rotation
  revokedAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([familyId])
}

// Magic sign-in (Slack-style, 2026-07-15): one row per requested email, carrying
// BOTH redemption shapes — the tokenized link and the 6-digit code the user can
// type on another device. Stored hashed only; single-use via atomic consume;
// the code path is brute-force-bound by `attempts` (row dies at MAX_CODE_ATTEMPTS).
model LoginToken {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation("UserLoginTokens", fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique // sha256 hex of the emailed link token
  codeHash   String // sha256 hex of "<loginTokenId>:<6-digit code>" (id-salted)
  expiresAt  DateTime // 15 minutes
  consumedAt DateTime?
  attempts   Int       @default(0) // failed code entries against this row
  createdAt  DateTime  @default(now())

  @@index([userId, createdAt])
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role Role

  // Scope (nullable based on role)
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  leagueId String?
  league   League? @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  gameId String? // For temporary scorekeeper role
  game   Game?   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  designation CoachDesignation? // coaching sub-type for team-scoped Staff/TeamManager
  expiresAt   DateTime? // For temporary roles

  createdAt DateTime @default(now())

  @@unique([userId, role, tenantId, teamId, leagueId, gameId])
  @@index([userId])
  @@index([tenantId])
  @@index([teamId])
  @@index([leagueId])
}

enum CoachDesignation {
  HeadCoach
  AssistantCoach
}

enum Role {
  ClubOwner
  ClubManager
  Staff
  TeamManager
  Scorekeeper
  LeagueOwner
  LeagueManager
  Parent
  Player
  Referee
  PlatformAdmin
}

// ============================================
// MULTI-TENANCY
// ============================================

model Tenant {
  id           String  @id @default(uuid())
  slug         String  @unique
  reviewInviteOverride String? // null = inherit platform reviewInvitePolicy
  name         String
  description  String? @db.Text
  phoneNumber  String?
  contactEmail String?
  address      String?
  city         String?
  state        String?
  zipCode      String?
  country      String  @default("US") // ISO 3166-1 alpha-2
  currency     String  @default("CAD") // ISO 4217
  website      String?
  customDomain String? @unique
  // Custom-domain plumbing (seo-strategy §6c; inert until CUSTOM_DOMAINS_ENABLED)
  customDomainVerifiedAt DateTime? // set by the DNS Verify endpoint
  customDomainCanonical  Boolean   @default(false) // false = mirror mode (their domain redirects to us)

  // Timezone (Recommended Addition)
  timezone String @default("America/New_York")

  // Stripe
  stripeAccountId     String? @unique
  stripeAccountStatus String? // active, pending, restricted

  // Subscription
  plan          TenantPlan   @default(FREE)
  planExpiresAt DateTime?
  status        TenantStatus @default(ACTIVE)

  // Paid placement: spotlighted in discovery surfaces (admin-toggled)
  isFeatured Boolean @default(false)

  // Relationships
  branding         TenantBranding?
  features         TenantFeatures?
  teams            Team[]
  staff            UserRole[]
  tryouts          Tryout[]
  practices        Practice[]
  venues           Venue[]
  announcements    Announcement[]
  payments         Payment[]         @relation("TenantPayments")
  paymentConfig    PaymentConfig?
  payerObligations PaymentObligation[] @relation("TenantPayerObligations")
  payeeObligations PaymentObligation[] @relation("TenantPayeeObligations")
  reviews          Review[]
  staffInvitations StaffInvitation[]
  playerInvitations PlayerInvitation[]
  clubClaims       ClubClaim[]
  houseLeagues     HouseLeague[]
  camps            Camp[]
  offerTemplates   OfferTemplate[]
  tournaments      Tournament[]
  postTags         PostTag[]
  follows          Follow[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([customDomain])
  // Homepage + public nav filter status IN (ACTIVE, UNCLAIMED) over ~190
  // imported clubs (perf audit 2026-07-06)
  @@index([status])
  reviewInvites ReviewInvite[] @relation("ReviewInvites")
}

enum TenantPlan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  UNCLAIMED
}

model TenantBranding {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  logoUrl        String? @db.Text
  faviconUrl     String?
  primaryColor   String  @default("#1a73e8")
  secondaryColor String  @default("#34a853")
  accentColor    String  @default("#fbbc04")
  fontFamily     String  @default("Inter")
  customCss      String? @db.Text

  // Customizable public page ("your website"): brand + layout.
  // Images stored as compressed data URLs (@db.Text) — no external blob infra.
  bannerUrl  String? @db.Text
  tagline    String?
  socials    Json? // { instagram, facebook, x, youtube, tiktok, ... }
  pageLayout Json? // [{ key, zone: "main"|"rail", order, visible, pinMobile }]

  emailLogoUrl String?
  emailFooter  String? @db.Text

  updatedAt DateTime @updatedAt
}

model TenantFeatures {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  enableTournaments Boolean @default(false)
  enableReviews     Boolean @default(true)
  enableChat        Boolean @default(false)
  enableAnalytics   Boolean @default(false)

  maxTeams  Int @default(10)
  maxStaff  Int @default(5)
  maxVenues Int @default(3)
}

// ============================================
// TEAMS & PLAYERS
// ============================================

model Team {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  ageGroup    String // U10, U12, U14, etc.
  gender      Gender?
  season      String? // "Spring 2026"
  description String? @db.Text

  // Relationships
  players           TeamPlayer[]
  staff             UserRole[]
  seasonSubmissions TeamSubmission[]
  homeGames         Game[]           @relation("HomeTeam")
  awayGames         Game[]           @relation("AwayTeam")
  practices         Practice[]
  announcements     Announcement[]
  offers            Offer[]
  offerTemplates    OfferTemplate[]
  tryouts           Tryout[]
  tournamentEntries TournamentTeam[]
  playerInvitations PlayerInvitation[]
  postTags          PostTag[]
  follows           Follow[]

  messages      TeamMessage[]
  chatMutes          ChatMute[]
  conversations      Conversation[]
  submissionRequests TeamSubmissionRequest[]
  chatReads     TeamChatRead[]
  polls         Poll[]
  practiceSlots PracticeSlot[]
  eventLinks    TeamEventTeam[]

  // Set when staff announce the practice schedule to families (bell+email);
  // the public team page shows practice days only after this.
  practiceScheduleAnnouncedAt DateTime?

  // Season continuity (docs/season-continuity-plan.md §2, owner-approved):
  // archived teams disappear from active lists but keep all history (games,
  // stats, chat read-only); lineage links a program's season instances
  // (Huskies U13 2025-26 → U14 2026-27) for rollover + future multi-season stats.
  archivedAt      DateTime?
  continuedFromId String?
  continuedFrom   Team?   @relation("TeamLineage", fields: [continuedFromId], references: [id], onDelete: SetNull)
  continuations   Team[]  @relation("TeamLineage")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([ageGroup])
  @@unique([tenantId, name, ageGroup, season])
}

// Team <-> family chat (TeamSnap-replacement messaging). One channel per
// team; members = team staff + club owners/managers + parents of rostered
// players. Soft delete keeps moderation history.
model TeamMessage {
  id     String @id @default(uuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation("TeamMessagesSent", fields: [senderId], references: [id], onDelete: Cascade)

  body String @db.Text

  // Quick poll posted into the stream (WhatsApp-style): the message carries
  // a single-question Poll; the bubble renders live result bars. SetNull so
  // deleting the poll from the polls page leaves the message as plain text.
  pollId String? @unique
  poll   Poll?   @relation(fields: [pollId], references: [id], onDelete: SetNull)

  deletedAt   DateTime?
  deletedById String?

  // Chat enrichment (2026-07-15): own-message edits + staff pins
  editedAt   DateTime?
  pinnedAt   DateTime?
  pinnedById String?

  reactions MessageReaction[]

  createdAt DateTime @default(now())

  @@index([teamId, createdAt])
  @@index([teamId, pinnedAt])
  @@index([senderId])
}

// Emoji reactions on team-chat messages (one per user+emoji+message).
model MessageReaction {
  id        String      @id @default(uuid())
  messageId String
  message   TeamMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation("MessageReactions", fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime    @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

// Per-user mute of one team's chat (no pushes/bell for that team).
model ChatMute {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation("ChatMutes", fields: [userId], references: [id], onDelete: Cascade)
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, teamId])
}

// Direct messages (2026-07-15): 1:1 threads inside a team context —
// adult-to-adult (staff↔parent, staff↔staff). pairKey = sorted
// "userA:userB:teamId" so a pair has exactly one thread per team.
model Conversation {
  id        String   @id @default(uuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  pairKey   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     DirectMessage[]

  @@index([teamId])
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("ConversationParticipants", fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime?
  createdAt      DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model DirectMessage {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("DirectMessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  body           String       @db.Text
  editedAt       DateTime?
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// Per-member read cursor for a team chat — unread badges + notification
// debounce both derive from it.
model TeamChatRead {
  userId String
  user   User   @relation("TeamChatReads", fields: [userId], references: [id], onDelete: Cascade)
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  lastReadAt DateTime @default(now())

  @@id([userId, teamId])
  @@index([teamId])
}

// Team events (owner ask 2026-07-07): arbitrary calendar entries — photo
// day, film session, fundraiser — living in the SAME team calendar as
// practices and games. One event can span multiple teams (club managers
// push club-wide, league owners push across their league's teams); staff
// of every attached team can edit. Members get a bell+email on add/change.
enum TeamEventStatus {
  SCHEDULED
  CANCELLED
}

enum TeamEventKind {
  WORKOUT
  TRAINING
  SCRIMMAGE
  MEETING
  OTHER
}

enum SubmissionRequestStatus {
  PENDING
  APPROVED
  DECLINED
  CANCELLED
}

// Coach/TeamManager "add my team to this league" REQUEST (2026-07-15):
// staff can't submit directly (payments hang off it) — a club operator
// approves, and approval performs the actual TeamSubmission.
model TeamSubmissionRequest {
  id       String @id @default(uuid())
  seasonId String
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  teamId   String
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  divisionId String
  // Roster version chosen by the requester (playerIds) — used at approval.
  playerIds Json?

  requestedById String
  requestedBy   User   @relation("SubmissionRequestsMade", fields: [requestedById], references: [id], onDelete: Cascade)

  status        SubmissionRequestStatus @default(PENDING)
  decidedById   String?
  decidedBy     User?     @relation("SubmissionRequestsDecided", fields: [decidedById], references: [id])
  decidedAt     DateTime?
  declineReason String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId, status])
  @@index([seasonId, status])
}

// One-time "score this game" invite (2026-07-15): a WhatsApp-able link for
// volunteer scorekeepers who aren't in the system. Token is game-scoped,
// expires after the game window, revocable; the volunteer's name is stamped
// on claim for the audit trail.
model GameScoreInvite {
  id        String @id @default(uuid())
  gameId    String
  game      Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  tokenHash String @unique

  createdById String
  createdBy   User   @relation("ScoreInvitesCreated", fields: [createdById], references: [id], onDelete: Cascade)

  expiresAt   DateTime
  revokedAt   DateTime?
  claimedAt   DateTime?
  claimedName String?

  createdAt DateTime @default(now())

  @@index([gameId])
}

model TeamEvent {
  id          String @id @default(uuid())
  createdById String
  createdBy   User   @relation("TeamEventsCreated", fields: [createdById], references: [id], onDelete: Cascade)

  title           String
  description     String? @db.Text
  location        String?
  startAt         DateTime
  durationMinutes Int      @default(60)

  // Typed events (2026-07-15): workout/lift, training, scrimmage… shown as
  // chips on every calendar surface
  eventType TeamEventKind @default(OTHER)

  status TeamEventStatus @default(SCHEDULED)

  teams TeamEventTeam[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startAt])
  @@index([createdById])
}

model TeamEventTeam {
  eventId String
  event   TeamEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  teamId  String
  team    Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([eventId, teamId])
  @@index([teamId])
}

// Team polls & surveys (engagement v1 — docs/engagement-features-plan.md).
// Same membership as team chat: staff create, staff + rostered families
// vote and see results. A poll holds 1..N questions so it doubles as a
// lightweight survey ("which tournaments should we enter?").
enum PollStatus {
  OPEN
  CLOSED
}

model Poll {
  id     String @id @default(uuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("PollsCreated", fields: [createdById], references: [id], onDelete: Cascade)

  title       String
  description String?    @db.Text
  status      PollStatus @default(OPEN)
  closedAt    DateTime?

  questions PollQuestion[]
  // Set when this poll was posted as a quick poll in the team chat
  chatMessage TeamMessage?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId, status])
  @@index([createdById])
}

model PollQuestion {
  id     String @id @default(uuid())
  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)

  prompt        String
  allowMultiple Boolean @default(false)
  order         Int     @default(0)

  options PollOption[]
  votes   PollVote[]

  @@index([pollId])
}

model PollOption {
  id         String       @id @default(uuid())
  questionId String
  question   PollQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  label String
  order Int    @default(0)

  votes PollVote[]

  @@index([questionId])
}

model PollVote {
  id         String       @id @default(uuid())
  questionId String
  question   PollQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  optionId   String
  option     PollOption   @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId     String
  user       User         @relation("PollVotes", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // One row per chosen option; re-voting replaces the user's rows for the
  // question in a transaction (single-choice = at most one row).
  @@unique([questionId, userId, optionId])
  @@index([questionId, userId])
  @@index([optionId])
}

enum Gender {
  MALE
  FEMALE
  COED
}

model Player {
  id String @id @default(uuid())

  // Personal Info
  firstName    String
  lastName     String
  dateOfBirth  DateTime
  gender       Gender
  jerseyNumber String?
  height       String? // e.g. "5'6"
  weight       Int? // in pounds
  position     String? // e.g. "Point Guard", "Center"

  // COPPA Compliance (Recommended Addition)
  isMinor              Boolean   @default(false) // Age < 13
  parentalConsentGiven Boolean? // Required if isMinor = true
  consentGivenAt       DateTime?
  canLogin             Boolean   @default(false) // Only true if 13+

  // Parental media consent — gates player-tagged public content AND opts
  // into full names on public stats/rosters/leaders (plan §5/§11.1)
  mediaConsent MediaConsent @default(UNSET)

  // Player handle — the marketable identity (docs/roadmap/player-handles-plan.md
  // P0). Claimed by the parent (or 13+ self); /p/<handle> resolves to the
  // player page. Lowercase, validated + reserved-word checked in lib/handles.
  handle String? @unique

  // Soft delete — set when parent removes the child. Preserves history (offers,
  // tryout signups, team rosters) but excludes from active listings.
  deletedAt DateTime?

  // Parent/Guardian
  parentId String
  parent   User   @relation("ParentPlayers", fields: [parentId], references: [id], onDelete: Cascade)

  // Relationships
  teams               TeamPlayer[]
  stats               PlayerStat[]
  offers              Offer[]
  houseLeagueSignups  HouseLeagueSignup[]
  campSignups         CampSignup[]
  seasonRosterEntries SeasonRosterPlayer[]
  postTags            PostTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([isMinor])
  tryoutSignups TryoutSignup[]
  rsvps         EventRsvp[]
}

model TeamPlayer {
  id     String @id @default(uuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  jerseyNumber  Int?
  uniformSize   String? // YS, YM, YL, AS, AM, AL, AXL
  shoeSize      String? // e.g. "7", "8.5"
  tracksuitSize String? // YS, YM, YL, AS, AM, AL, AXL

  status   TeamPlayerStatus @default(ACTIVE)
  joinedAt DateTime         @default(now())
  leftAt   DateTime?

  withdrawalRequests WithdrawalRequest[]

  @@unique([teamId, playerId])
  @@index([teamId])
  @@index([playerId])
}

enum TeamPlayerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ============================================
// REFEREE PROFILES (Recommended Addition)
// ============================================

model RefereeProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Certifications
  certificationLevel  String? // "Level 1", "Level 2", etc.
  certificationExpiry DateTime?

  // Availability
  availableRegions String[] // ["California", "Nevada"]

  // Fee
  standardFee Decimal @db.Decimal(10, 2)

  // Stripe Connect
  stripeAccountId     String? @unique
  stripeAccountStatus String?

  // Scoresheet sign-off PIN (bcrypt hash) — entered at the scorer's table to
  // approve a final score as the assigned referee
  signoffPinHash String?

  // Stats
  gamesRefereed Int      @default(0)
  averageRating Decimal? @db.Decimal(3, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ============================================
// TRYOUTS & OFFERS
// ============================================

model Tryout {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  title       String
  description String? @db.Text
  ageGroup    String
  gender      Gender?

  location    String
  scheduledAt DateTime
  duration    Int? // minutes

  fee             Decimal @db.Decimal(10, 2)
  maxParticipants Int?

  isPublished Boolean @default(false)
  isPublic    Boolean @default(true)

  // Relationships
  signups TryoutSignup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([teamId])
  @@index([scheduledAt])
  @@index([isPublished, isPublic])
}

model TryoutSignup {
  id       String @id @default(uuid())
  tryoutId String
  tryout   Tryout @relation(fields: [tryoutId], references: [id], onDelete: Cascade)

  userId String // Parent
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identity thread to the real Player (restores tryout->offer linkage);
  // nullable because a signup may predate the Player record. Name/age stay
  // as a point-in-time snapshot.
  playerId String?
  player   Player? @relation(fields: [playerId], references: [id], onDelete: SetNull)

  playerName   String
  playerAge    Int
  playerGender Gender

  status    TryoutSignupStatus @default(PENDING)
  paymentId String?            @unique
  payment   Payment?           @relation(fields: [paymentId], references: [id])

  notes String? @db.Text

  // Tryout-day roll-call: set when the player arrives, cleared if mis-tapped.
  // Orthogonal to status (payment/offer pipeline) — null after the tryout = no-show.
  checkedInAt DateTime?

  // Relationships
  offers Offer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tryoutId, userId, playerName])
  @@unique([tryoutId, playerId])
  @@index([tryoutId])
  @@index([userId])
  @@index([playerId])
}

enum TryoutSignupStatus {
  PENDING
  PAID
  CONFIRMED
  CANCELLED
  OFFERED
}

model OfferTemplate {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Legacy: was team-scoped, now club-scoped. Kept nullable for existing data.
  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  name String // e.g. "Standard Package", "Premium Package"

  seasonFee        Decimal @db.Decimal(10, 2)
  installments     Int     @default(1)
  practiceSessions Int     @default(0)

  // Included items
  includesBall      Boolean @default(false) // basketball
  includesBag       Boolean @default(false) // equipment bag
  includesShoes     Boolean @default(false)
  includesUniform   Boolean @default(false) // shirt + shorts
  includesTracksuit Boolean @default(false)

  isActive Boolean @default(true)

  offers            Offer[]
  playerInvitations PlayerInvitation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Offer {
  id     String @id @default(uuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  tryoutSignupId String?
  tryoutSignup   TryoutSignup? @relation(fields: [tryoutSignupId], references: [id])

  templateId String?
  template   OfferTemplate? @relation(fields: [templateId], references: [id])

  status OfferStatus @default(PENDING)

  // Offer details (copied from template, tweakable per offer)
  seasonFee        Decimal @db.Decimal(10, 2)
  installments     Int     @default(1)
  practiceSessions Int     @default(0)

  // Included items
  includesBall      Boolean @default(false)
  includesBag       Boolean @default(false)
  includesShoes     Boolean @default(false)
  includesUniform   Boolean @default(false)
  includesTracksuit Boolean @default(false)

  // Package options presented to the family (docs/offer-package-options-
  // design.md). Rows exist only for multi-option offers; the family picks
  // one at accept and its values overwrite the snapshot columns above, so
  // Order Sheet / payments / roster read the same columns as always.
  options        OfferOption[] @relation("OfferOptions")
  chosenOptionId String?       @unique
  chosenOption   OfferOption?  @relation("ChosenOption", fields: [chosenOptionId], references: [id])
  // Which way the family chose to pay at accept (payments v2 Stage C)
  paymentPlan PaymentPlan?

  message   String?  @db.Text
  expiresAt DateTime

  // Filled on acceptance by parent/player
  uniformSize   String? // YS, YM, YL, AS, AM, AL, AXL
  shoeSize      String? // e.g. "7", "8.5"
  tracksuitSize String? // YS, YM, YL, AS, AM, AL, AXL
  jerseyPref1   Int? // First choice jersey number
  jerseyPref2   Int? // Second choice jersey number
  jerseyPref3   Int? // Third choice jersey number

  respondedAt DateTime?

  playerInvitation PlayerInvitation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId])
  @@index([playerId])
  @@index([tryoutSignupId])
  @@index([templateId])
  @@index([status])
}

// One package choice on a multi-option offer ("Returning Player $950" /
// "New Player $1,250"). A COPY seeded from a template at send time —
// later template edits never disturb sent offers.
model OfferOption {
  id      String @id @default(uuid())
  offerId String
  offer   Offer  @relation("OfferOptions", fields: [offerId], references: [id], onDelete: Cascade)

  label            String
  sourceTemplateId String?

  seasonFee        Decimal @db.Decimal(10, 2)
  installments     Int     @default(1)
  practiceSessions Int     @default(0)

  includesBall      Boolean @default(false)
  includesBag       Boolean @default(false)
  includesShoes     Boolean @default(false)
  includesUniform   Boolean @default(false)
  includesTracksuit Boolean @default(false)

  sortOrder Int @default(0)

  // Payment terms the CLUB sets on this package (payments v2 Stage B).
  // Full payment and/or an installment plan = a deposit (due on accept) +
  // OfferInstallmentTerm rows (each an amount + due date). Snapshotted here
  // because the option is already offer-scoped.
  allowFullPay     Boolean @default(true)
  allowInstallments Boolean @default(false)
  depositAmount    Decimal? @db.Decimal(10, 2)
  installmentTerms OfferInstallmentTerm[]

  chosenBy Offer? @relation("ChosenOption")

  createdAt DateTime @default(now())

  @@index([offerId])
}

// One installment on an option's payment plan: "$750 due Oct 1". Amounts
// across a plan (deposit + terms) sum to the option's seasonFee.
model OfferInstallmentTerm {
  id       String      @id @default(uuid())
  optionId String
  option   OfferOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  sequence Int // 1..N after the deposit
  label    String?
  amount   Decimal  @db.Decimal(10, 2)
  dueDate  DateTime

  @@index([optionId])
}

enum PaymentPlan {
  FULL
  INSTALLMENTS
}

// A payer's Stripe Customer on a CLUB's connected account (direct-charge
// mode only). Direct charges + saved cards must live on the connected
// account, so a payer has one of these per direct-charge club they pay.
model ConnectedCustomer {
  id         String @id @default(uuid())
  userId     String
  user       User   @relation("ConnectedCustomers", fields: [userId], references: [id], onDelete: Cascade)
  accountId  String // the club's connected account (acct_…)
  customerId String // the Stripe customer on that account (cus_…)

  createdAt DateTime @default(now())

  @@unique([userId, accountId])
  @@index([userId])
}

enum OfferStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  RESCINDED // withdrawn by the club while still PENDING (owner decision 2026-07-09)
}

// ============================================
// LEAGUES, SEASONS & GAMES
// ============================================

model League {
  id              String  @id @default(uuid())
  name            String
  description     String? @db.Text
  ownerId         String
  currency        String  @default("CAD")
  stripeAccountId String? @unique

  // Customizable public page branding (docs/roadmap/customizable-pages.md).
  logoUrl      String? @db.Text
  bannerUrl    String? @db.Text
  tagline      String?
  primaryColor String  @default("#1a73e8")
  socials      Json?

  // Live-scoring configuration (docs/live-scoring-design.md) — owner-confirmed
  // defaults: STANDARD depth, simple clock ON.
  statDepth     StatDepth  @default(STANDARD)
  gameClockMode ClockMode  @default(SIMPLE)
  periodType    PeriodType @default(QUARTERS)
  periodMinutes Int        @default(10)
  // Referee signs the scoresheet before a game can be finalized
  requireRefereeApproval Boolean @default(false)

  seasons Season[]
  staff   UserRole[]
  reviews Review[]
  paymentConfig PaymentConfig?
  obligations   PaymentObligation[] @relation("LeagueObligations")
  leagueReferees  LeagueReferee[]
  refereeRequests RefereeSessionRequest[] @relation("LeagueRefereeRequests")
  postTags      PostTag[]
  follows       Follow[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Season {
  id       String @id @default(uuid())
  leagueId String
  league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  label String
  type  SeasonType @default(FALL_WINTER)

  startDate            DateTime?
  endDate              DateTime?
  registrationDeadline DateTime?
  ageGroupCutoffDate   DateTime?

  // Roster edits after lock: policy + optional hard deadline
  rosterChangePolicy   RosterChangePolicy @default(REQUEST_ONLY)
  rosterChangeDeadline DateTime?

  teamFee  Decimal? @db.Decimal(10, 2)
  currency String   @default("CAD")

  gameSlotMinutes     Int    @default(90)
  gameLengthMinutes   Int    @default(40)
  gamePeriods         String @default("HALVES")
  periodLengthMinutes Int?

  gamesGuaranteed         Int?
  targetGamesPerSession   Int?
  idealGamesPerDayPerTeam Int  @default(1)

  defaultVenueOpenTime  String @default("09:00")
  defaultVenueCloseTime String @default("20:00")

  schedulingPhilosophy         SchedulingPhilosophy @default(FAMILY_FRIENDLY)
  allowCrossDivisionScheduling Boolean              @default(false)

  tiebreakerOrder     String[]  @default([])
  tiebreakersLockedAt DateTime?

  status SeasonStatus @default(DRAFT)

  playoffFormat String?
  playoffTeams  Int?

  divisions        Division[]
  teamSubmissions  TeamSubmission[]
  submissionRequests TeamSubmissionRequest[]
  sessions         SeasonSession[]
  seasonVenues     SeasonVenue[]
  rosters          SeasonRoster[]
  games            Game[]
  schedulingGroups SchedulingGroup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leagueId])
  @@index([status])
  @@unique([leagueId, label])
  reviewInvites ReviewInvite[]
}

enum SeasonStatus {
  DRAFT
  REGISTRATION
  REGISTRATION_CLOSED
  FINALIZED
  IN_PROGRESS
  COMPLETED
}

enum SeasonType {
  FALL_WINTER
  SUMMER
  SPRING
  CUSTOM
}

enum SchedulingPhilosophy {
  FAMILY_FRIENDLY
  SPREAD_DAYS
}

model Division {
  id       String @id @default(uuid())
  seasonId String
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  name     String
  ageGroup String
  gender   Gender?
  tier     Int     @default(1)
  maxTeams Int?

  teamSubmissions  TeamSubmission[]
  schedulingGroups SchedulingGroupDivision[]

  @@index([seasonId])
}

model TeamSubmission {
  id       String @id @default(uuid())
  seasonId String
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  divisionId String?
  division   Division? @relation(fields: [divisionId], references: [id])

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  status          TeamSubmissionStatus      @default(PENDING)
  paymentStatus   RegistrationPaymentStatus @default(UNPAID)
  registrationFee Decimal?                  @db.Decimal(10, 2)
  paymentId       String?                   @unique
  payment         Payment?                  @relation(fields: [paymentId], references: [id])

  roster    SeasonRoster?
  blackouts SeasonTeamBlackout[]

  createdAt DateTime @default(now())

  withdrawalRequests WithdrawalRequest[]

  @@unique([seasonId, teamId])
  @@index([seasonId])
  @@index([teamId])
}

enum TeamSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

enum RegistrationPaymentStatus {
  UNPAID
  PAID_MANUAL
  PAID_STRIPE
  WAIVED
}

model SeasonRoster {
  id       String @id @default(uuid())
  seasonId String
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  teamSubmissionId String         @unique
  teamSubmission   TeamSubmission @relation(fields: [teamSubmissionId], references: [id], onDelete: Cascade)

  isLocked    Boolean   @default(false)
  submittedAt DateTime?
  lockedAt    DateTime?

  players        SeasonRosterPlayer[]
  changeRequests RosterChangeRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([seasonId])
}

// Club asks the league to reopen a locked season roster; commissioner
// approves (one-shot unlock — the next roster save re-locks) or denies.
model RosterChangeRequest {
  id       String       @id @default(uuid())
  rosterId String
  roster   SeasonRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  requestedById String
  requestedBy   User   @relation("RosterChangeRequests", fields: [requestedById], references: [id], onDelete: Cascade)

  message String @db.Text

  // Structured changes (2026-07-15): playerIds to add / roster playerIds to
  // remove — approval APPLIES them to the locked roster. Free-text `message`
  // stays as the optional note.
  additions Json?
  removals  Json?

  status         RosterChangeRequestStatus @default(PENDING)
  resolvedById   String?
  resolvedBy     User?     @relation("RosterChangeResolutions", fields: [resolvedById], references: [id])
  resolutionNote String?   @db.Text
  resolvedAt     DateTime?

  createdAt DateTime @default(now())

  @@index([rosterId])
  @@index([status])
}

enum RosterChangeRequestStatus {
  PENDING
  APPROVED
  DENIED
}

// How a league handles roster edits after rosters lock at finalization
enum RosterChangePolicy {
  OPEN_UNTIL_DEADLINE // clubs edit freely until rosterChangeDeadline
  REQUEST_ONLY // clubs must ask; commissioner approves per change
  CLOSED // locked means locked
}

model SeasonRosterPlayer {
  id       String       @id @default(uuid())
  rosterId String
  roster   SeasonRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  playerId String
  player   Player @relation(fields: [playerId], references: [id])

  jerseyNumber Int?
  position     String?

  createdAt DateTime @default(now())

  @@unique([rosterId, playerId])
  @@index([rosterId])
  @@index([playerId])
}

model SeasonSession {
  id       String @id @default(uuid())
  seasonId String
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  label              String?
  phase              SessionPhase @default(REGULAR)
  targetGamesPerTeam Int?

  // Bracket/advancement plan JSON (lib/playoffs/generate.ts)
  playoffPlan Json?
  days  SeasonSessionDay[]
  games Game[]

  createdAt DateTime @default(now())

  @@index([seasonId])
}

enum SessionPhase {
  REGULAR
  PLAYOFF
}


model SeasonSessionDay {
  id        String        @id @default(uuid())
  sessionId String
  session   SeasonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  date DateTime

  dayVenues       SeasonSessionDayVenue[]
  games           Game[]
  refereeRequests RefereeSessionRequest[]

  @@index([sessionId])
  @@index([date])
}

// The league's own referee pool — refs the commissioner knows and books
model LeagueReferee {
  id       String @id @default(uuid())
  leagueId String
  league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation("LeagueReferees", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([leagueId, userId])
  @@index([userId])
}

// Referee-declared availability windows, one row per day-slot
model RefereeAvailability {
  id     String @id @default(uuid())
  userId String
  user   User   @relation("RefereeAvailabilities", fields: [userId], references: [id], onDelete: Cascade)

  date      DateTime // calendar day (midnight)
  startTime String // "09:00"
  endTime   String // "18:00"
  note      String?

  createdAt DateTime @default(now())

  @@index([userId, date])
  @@index([date])
}

// Uber-style shift offer for a session day: targeted at one referee, or
// broadcast to the league pool (targetUserId null, first accept wins).
// Accepting auto-assigns the referee to that day's games in the window.
model RefereeSessionRequest {
  id       String @id @default(uuid())
  leagueId String
  league   League @relation("LeagueRefereeRequests", fields: [leagueId], references: [id], onDelete: Cascade)

  sessionDayId String
  sessionDay   SeasonSessionDay @relation(fields: [sessionDayId], references: [id], onDelete: Cascade)

  targetUserId String?
  targetUser   User?   @relation("TargetedRefereeRequests", fields: [targetUserId], references: [id], onDelete: Cascade)

  startTime String // shift the league enforces ("09:00")
  endTime   String
  message   String? @db.Text

  status       RefereeRequestStatus @default(PENDING)
  acceptedById String?
  acceptedBy   User?                @relation("AcceptedRefereeRequests", fields: [acceptedById], references: [id])
  respondedAt  DateTime?

  createdById String

  createdAt DateTime @default(now())

  @@index([leagueId, status])
  @@index([targetUserId, status])
  @@index([sessionDayId])
}

enum RefereeRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

model SeasonSessionDayVenue {
  id    String           @id @default(uuid())
  dayId String
  day   SeasonSessionDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id])

  startTime String?
  endTime   String?

  courts SeasonSessionDayVenueCourt[]
  games  Game[]

  @@index([dayId])
  @@index([venueId])
}

model SeasonSessionDayVenueCourt {
  id         String                @id @default(uuid())
  dayVenueId String
  dayVenue   SeasonSessionDayVenue @relation(fields: [dayVenueId], references: [id], onDelete: Cascade)

  courtId String
  court   Court  @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@unique([dayVenueId, courtId])
  @@index([dayVenueId])
  @@index([courtId])
}

model SeasonVenue {
  id       String @id @default(uuid())
  seasonId String
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id])

  isPrimary       Boolean @default(false)
  courtsAvailable Int?

  @@unique([seasonId, venueId])
  @@index([seasonId])
}

model SchedulingGroup {
  id       String @id @default(uuid())
  seasonId String
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  name      String
  divisions SchedulingGroupDivision[]

  createdAt DateTime @default(now())

  @@index([seasonId])
}

model SchedulingGroupDivision {
  schedulingGroupId String
  schedulingGroup   SchedulingGroup @relation(fields: [schedulingGroupId], references: [id], onDelete: Cascade)

  divisionId String
  division   Division @relation(fields: [divisionId], references: [id], onDelete: Cascade)

  @@id([schedulingGroupId, divisionId])
  @@index([divisionId])
}

model SeasonTeamBlackout {
  id               String         @id @default(uuid())
  teamSubmissionId String
  teamSubmission   TeamSubmission @relation(fields: [teamSubmissionId], references: [id], onDelete: Cascade)

  date      DateTime
  startTime String?
  endTime   String?
  reason    String?

  createdAt DateTime @default(now())

  @@index([teamSubmissionId])
}

model Game {
  id String @id @default(uuid())

  seasonId String?
  season   Season? @relation(fields: [seasonId], references: [id])

  phase SessionPhase?

  sessionId String?
  session   SeasonSession? @relation(fields: [sessionId], references: [id])

  dayId String?
  day   SeasonSessionDay? @relation(fields: [dayId], references: [id])

  dayVenueId String?
  dayVenue   SeasonSessionDayVenue? @relation(fields: [dayVenueId], references: [id])

  courtId String?
  court   Court?  @relation(fields: [courtId], references: [id])

  homeTeamId String
  homeTeam   Team   @relation("HomeTeam", fields: [homeTeamId], references: [id])

  awayTeamId String
  awayTeam   Team   @relation("AwayTeam", fields: [awayTeamId], references: [id])

  venueId String?
  venue   Venue?  @relation(fields: [venueId], references: [id])

  scheduledAt DateTime
  duration    Int        @default(90)
  status      GameStatus @default(SCHEDULED)

  homeScore Int?
  awayScore Int?

  isLocked    Boolean @default(false)
  defaultedBy String?

  // Scorekeeper's pre-game clock choice (owner 2026-07-15): null inherits the
  // league's gameClockMode; true/false overrides per game — an unoperated
  // clock is worse than none, so the person at the table decides.
  clockEnabled Boolean?

  // Playoffs (owner 2026-07-18): round number (1 = first round) + slot index
  // within the round. Later-round games are created by advancePlayoffs() as
  // winners emerge — the bracket plan lives on the session's playoffPlan.
  playoffRound Int?
  playoffSlot  Int?

  // Single active scoring device (soft lock with visible takeover)
  scoringSessionId   String?
  scoringSessionUser String?
  scoringSessionAt   DateTime?

  // Referee sign-off at finalize (paper-scoresheet style; league-configurable)
  refereeName     String?
  refereeSignedAt DateTime?
  // Drawn signature (PNG data URL from the console's signature pad)
  refereeSignature String? @db.Text
  // True when the sign-off was PIN-verified against the ASSIGNED referee's
  // account (UserRole role=Referee gameId=this game) — the strong approval.
  refereeVerified Boolean @default(false)

  events       GameEvent[]
  scoreInvites GameScoreInvite[]
  stats        PlayerStat[]
  scorekeepers UserRole[]
  postTags     PostTag[]

  finalizedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([seasonId])
  @@index([sessionId])
  @@index([dayId])
  @@index([dayVenueId])
  @@index([courtId])
  @@index([venueId])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([scheduledAt])
  @@index([status])
  // Scoreboard strips / /scores filter status + scheduledAt-range together;
  // standings + leaders filter seasonId + status (perf audit 2026-07-06)
  @@index([status, scheduledAt])
  @@index([seasonId, status])
}

enum GameStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
  POSTPONED
  DEFAULTED
}

// Append-only scoring stream (docs/live-scoring-design.md). Nothing is ever
// edited or deleted — corrections VOID events. Score, box score, on-floor
// state and PlayerStat rows are all derived by folding this stream.
model GameEvent {
  id     String @id @default(uuid())
  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  eventType GameEventType
  teamId    String? // scoring/fouling team; null for period/clock events
  playerId  String? // Player involved

  made      Boolean? // shots: made vs missed
  points    Int? // For SCORE events
  period    Int? // 1-4 (quarters) or 1-2 (halves)
  clockSeconds Int? // seconds remaining in the period when recorded
  timestamp DateTime @default(now())

  // Per-game monotonic order (server-assigned) + offline idempotency key
  sequence      Int     @default(0)
  clientEventId String? @unique
  voided        Boolean @default(false)
  recordedById  String?

  metadata Json? // SUBSTITUTION {inPlayerId,outPlayerId}, LINEUP {playerIds}, REBOUND {offensive}

  @@index([gameId, sequence])
  @@index([gameId])
  @@index([teamId])
  @@index([playerId])
}

enum GameEventType {
  SCORE_2PT
  SCORE_3PT
  SCORE_FT
  REBOUND
  ASSIST
  STEAL
  BLOCK
  TURNOVER
  FOUL
  TIMEOUT
  SUBSTITUTION
  LINEUP
  ATTENDANCE
  PERIOD_START
  PERIOD_END
  CLOCK_START
  CLOCK_STOP
}

enum StatDepth {
  SCORE_ONLY
  STANDARD
  FULL
}

enum ClockMode {
  SIMPLE
  OFF
}

enum PeriodType {
  QUARTERS
  HALVES
}

model PlayerStat {
  id     String @id @default(uuid())
  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  // Stats (Auto-calculated from GameEvents)
  points    Int @default(0)
  rebounds  Int @default(0)
  assists   Int @default(0)
  steals    Int @default(0)
  blocks    Int @default(0)
  turnovers Int @default(0)
  fouls     Int @default(0)

  minutesPlayed Int?

  @@unique([gameId, playerId])
  @@index([gameId])
  @@index([playerId])
}

// ============================================
// VENUES & PRACTICES
// ============================================

model Venue {
  id       String  @id @default(uuid())
  tenantId String? // Optional — venues are global
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  name        String
  address     String
  city        String
  state       String
  zipCode     String?
  country     String  @default("CA")
  phoneNumber String?

  // Google Places
  placeId   String? @unique // Google Place ID for dedup
  latitude  Float?
  longitude Float?

  capacity Int?
  courts   Int? // Legacy count — courts[] is the source of truth going forward
  notes    String? @db.Text

  games            Game[]
  practices        Practice[]
  seasonVenues     SeasonVenue[]
  dayVenues        SeasonSessionDayVenue[]
  courtList        Court[]
  venueHours       VenueHours[]
  tournamentVenues TournamentVenue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([city])
  @@index([name])
}

model Court {
  id      String @id @default(uuid())
  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  name         String
  displayOrder Int    @default(0)

  dayVenueCourts SeasonSessionDayVenueCourt[]
  games          Game[]

  createdAt DateTime @default(now())

  @@index([venueId])
}

model VenueHours {
  id      String @id @default(uuid())
  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  dayOfWeek Int // 0 = Sunday ... 6 = Saturday
  openTime  String? // null = closed that day
  closeTime String?

  @@unique([venueId, dayOfWeek])
  @@index([venueId])
}

model Practice {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  venueId String?
  venue   Venue?  @relation(fields: [venueId], references: [id])
  // Free-text fallback ("Main Gym") — practices rarely justify a Venue row
  location String?

  scheduledAt DateTime
  duration    Int // minutes

  // Which recurring slot generated this occurrence (null = one-off);
  // announce re-runs skip dates already covered by the same slot.
  slotId String?
  slot   PracticeSlot? @relation(fields: [slotId], references: [id], onDelete: SetNull)

  notes  String?        @db.Text
  status PracticeStatus @default(SCHEDULED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([teamId, scheduledAt])
  @@index([scheduledAt])
}

// Recurring practice pattern ("Tue 6:30 PM, 90 min, Main Gym") — defined at
// team creation or later (TBD = no slots). Announce generates Practice
// occurrences from these and notifies the team
// (docs/engagement-features-plan.md → practices).
model PracticeSlot {
  id     String @id @default(uuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  dayOfWeek       Int // 0 = Sunday … 6 = Saturday
  startTime       String // "18:30" wall time in the app timezone
  durationMinutes Int    @default(90)
  location        String?

  practices Practice[]

  createdAt DateTime @default(now())

  @@index([teamId])
}

enum PracticeStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

// ============================================
// RSVP (calendar items — docs/feature-backlog.md spec)
// ============================================

enum RsvpStatus {
  GOING
  NOT_GOING
  MAYBE
}

enum RsvpItemType {
  PRACTICE
  GAME
  TEAM_EVENT
}

// Keyed on the PLAYER (whose attendance matters); submitted by the parent
// or the 13+ self-player (respondedBy). itemId is a soft reference into
// Practice/Game/TeamEvent by itemType — items live in three tables, so no
// FK; the API validates existence + roster membership.
model EventRsvp {
  id String @id @default(uuid())

  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  itemType RsvpItemType
  itemId   String

  status RsvpStatus
  note   String?

  respondedById String
  respondedBy   User   @relation("RsvpResponses", fields: [respondedById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([playerId, itemType, itemId])
  @@index([itemType, itemId])
}

// ============================================
// PROGRAM STAFF (docs/roadmap/program-staff-plan.md)
// ============================================

enum ProgramType {
  CAMP
  HOUSE_LEAGUE
  TOURNAMENT // enum reserved; assignment UI deferred (owner 2026-07-11)
}

enum ProgramStaffDesignation {
  LEAD
  ASSISTANT
}

// Who runs a program: a LEAD (person in charge) + ASSISTANTs. Soft ref by
// (programType, programId) — camps/HLs/tournaments live in three tables
// with no shared parent (same pattern as EventRsvp). Assignment grants
// manage-lite (view registrants, check-in, edit description/schedule);
// pricing/publish/delete stay with club admins.
model ProgramStaff {
  id String @id @default(uuid())

  programType ProgramType
  programId   String

  userId String
  user   User   @relation("ProgramAssignments", fields: [userId], references: [id], onDelete: Cascade)

  designation  ProgramStaffDesignation @default(ASSISTANT)
  assignedById String

  createdAt DateTime @default(now())

  @@unique([programType, programId, userId])
  @@index([userId])
  @@index([programType, programId])
}

// ============================================
// PAYMENTS (Enhanced with Installments)
// ============================================

model Payment {
  id String @id @default(uuid())

  // Stripe
  stripePaymentIntentId String? @unique
  stripeChargeId        String? @unique
  // Connected account the charge lives on (CONNECT_DIRECT) — null = platform
  stripeAccountId       String?
  // PLATFORM_COLLECT destination charges: the connected account the club's
  // share transfers to at charge time; refunds must reverse_transfer.
  stripeDestinationAccountId String?
  // Auto-collect invoice backing a scheduled installment (payments v2 hybrid).
  // Cron finalizes it on the due date; Stripe charges + Smart-Retries + duns.
  stripeInvoiceId String? @unique

  // Parties — payer may be a person (family flows) or an organization via
  // the obligation (club→league team fees), hence nullable.
  payerId String?
  payer   User?   @relation("PayerPayments", fields: [payerId], references: [id])

  payeeId String? // Club/League owner
  payee   User?   @relation("PayeePayments", fields: [payeeId], references: [id])

  tenantId String? // If club payment
  tenant   Tenant? @relation("TenantPayments", fields: [tenantId], references: [id])

  // Payment Details
  amount      Decimal  @db.Decimal(10, 2)
  currency    String   @default("CAD") // ISO 4217, uppercase like every other money field
  platformFee Decimal? @db.Decimal(10, 2)

  status PaymentStatus @default(PENDING)

  // Installments (Recommended Addition)
  dueDate           DateTime? // For installment payments
  installmentNumber Int? // 1, 2, 3, 4
  relatedOfferId    String? // Link installments together

  // Context
  paymentType PaymentType
  description String?

  // Obligation thread + rail (docs/payments-design.md)
  obligationId String?
  obligation   PaymentObligation? @relation(fields: [obligationId], references: [id])
  method       PaymentMethod      @default(STRIPE)
  // Club staff who recorded an offline payment (cash/e-transfer bookkeeping)
  recordedById String?
  recordedBy   User?   @relation("RecordedPayments", fields: [recordedById], references: [id])
  note         String?

  // Relationships
  tryoutSignup   TryoutSignup?
  teamSubmission TeamSubmission?

  // Refund
  refundedAt   DateTime?
  refundAmount Decimal?  @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([payerId])
  @@index([payeeId])
  @@index([tenantId])
  @@index([status])
  @@index([paymentType])
  @@index([dueDate])
  @@index([relatedOfferId])
  @@index([obligationId])
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  DISPUTED
}

enum PaymentType {
  TRYOUT_FEE
  SEASON_FEE
  LEAGUE_FEE
  TOURNAMENT_FEE
  REFEREE_FEE
  OTHER
}

enum PaymentMethod {
  STRIPE
  CASH
  ETRANSFER
  CHEQUE
  OTHER
}

enum OnlineMode {
  NONE
  CONNECT_DIRECT
  PLATFORM_COLLECT
}

enum ObligationStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  WAIVED
  CANCELLED
  REFUNDED
}

// Per-merchant payment configuration (docs/payments-design.md). A merchant is
// a club (tenant) today; leagues join in phase 2 — hence the polymorphic
// owner, exactly one of tenantId/leagueId set. Platform admin controls the
// allowlist + fees; the merchant chooses within it.
model PaymentConfig {
  id       String  @id @default(uuid())
  tenantId String? @unique
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leagueId String? @unique
  league   League? @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  // Platform-admin allowlist overrides — null inherits PlatformSettings.pay*
  offlineAllowed         Boolean?
  connectAllowed         Boolean?
  platformCollectAllowed Boolean?

  // Merchant choices (validated against the allowlist)
  offlineEnabled Boolean         @default(true)
  offlineMethods PaymentMethod[] @default([CASH, ETRANSFER])
  onlineMode     OnlineMode? // null inherits payDefaultOnlineMode

  // Installment reminders (payments v2 Stage F) — our branded pre-due nudge
  reminderLeadDays Int     @default(3)
  reminderEmail    Boolean @default(true)
  reminderPush     Boolean @default(false) // web push is a fast-follow

  // Platform fee overrides on ONLINE charges — null inherits PlatformSettings
  platformFeeBps  Int?
  platformFeeFlat Decimal? @db.Decimal(10, 2)

  // Stripe Connect (stage 2)
  stripeAccountId     String? @unique
  stripeAccountStatus String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// What is OWED, separate from the payments made against it. One obligation
// per product row (tryout signup, offer, camp signup, …); payments — cash or
// Stripe alike — reference it, so offline and online revenue report the same.
model PaymentObligation {
  id String @id @default(uuid())

  // Payer — a person (family flows) or a club (club→league/club flows, phase 2)
  payerUserId   String?
  payerUser     User?   @relation("UserObligations", fields: [payerUserId], references: [id])
  payerTenantId String?
  payerTenant   Tenant? @relation("TenantPayerObligations", fields: [payerTenantId], references: [id])

  // Merchant (payee) — club now, league in phase 2
  payeeTenantId String?
  payeeTenant   Tenant? @relation("TenantPayeeObligations", fields: [payeeTenantId], references: [id])
  payeeLeagueId String?
  payeeLeague   League? @relation("LeagueObligations", fields: [payeeLeagueId], references: [id])

  // What it's for
  referenceType String // "TryoutSignup" | "Offer" | "CampSignup" | "HouseLeagueSignup" | "TeamSubmission" | "TournamentEntry"
  referenceId   String
  description   String

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("CAD")

  status  ObligationStatus @default(PENDING)
  dueDate DateTime?

  waivedAt     DateTime?
  waivedReason String?

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([referenceType, referenceId])
  @@index([payeeTenantId, status])
  @@index([payeeLeagueId, status])
  @@index([payerUserId, status])
  @@index([payerTenantId, status])
}

// ============================================
// COMMUNICATIONS
// ============================================

model Announcement {
  id       String  @id @default(uuid())
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  title   String
  content String @db.Text

  isPinned Boolean @default(false)
  // Public announcements flow into the homepage/entity news feeds
  // (docs/public-site-content-plan.md §6)
  isPublic Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([teamId])
  @@index([createdAt])
  @@index([isPublic, createdAt])
}

// ============================================
// PUBLIC CONTENT & FOLLOWS
// (docs/public-site-content-plan.md — P1: RECAP_AI posts + Follow;
//  P2 adds creator posts + MediaAsset)
// ============================================

model Post {
  id    String   @id @default(uuid())
  kind  PostKind
  title String
  slug  String   @unique
  body  String   @db.Text

  status      PostStatus @default(DRAFT)
  publishedAt DateTime?

  authorId String?
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  // RECAP_AI provenance: "template" or the model id that wrote it
  aiModel String?

  tags  PostTag[]
  media MediaAsset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt])
  @@index([kind, status, publishedAt])
}

// Media on a post (plan §5/§9): IMAGE covers photos (Vercel Blob in P2;
// external URLs fine for embeds/demo), VIDEO_EMBED is YouTube/Vimeo (P2 PoC
// per §11.3), VIDEO_NATIVE arrives with P3 (Mux/Cloudflare Stream).
model MediaAsset {
  id     String @id @default(uuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  type      MediaAssetType
  url       String
  posterUrl String?
  title     String?
  durationS Int?
  width     Int?
  height    Int?
  sortOrder Int    @default(0)

  createdAt DateTime @default(now())

  @@index([postId])
  @@index([type])
}

enum MediaAssetType {
  IMAGE
  VIDEO_EMBED
  VIDEO_NATIVE
}

enum PostKind {
  ARTICLE
  PHOTO_SET
  VIDEO
  RECAP_AI
  ANNOUNCEMENT
}

enum PostStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  TAKEN_DOWN
}

// Tags are DISTRIBUTION: a post tagged to a team appears on the team page,
// its club page, its league feed, and followers' homepages.
model PostTag {
  id     String @id @default(uuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  leagueId String?
  league   League? @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  gameId String?
  game   Game?   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  playerId String?
  player   Player? @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([teamId])
  @@index([tenantId])
  @@index([leagueId])
  @@index([gameId])
  @@index([playerId])
}

// FOLLOW any team/club/league; parents' kids' teams are auto-included at
// query time (derived, not materialized). Follows drive the signed-in
// "Your teams" rail and, later, notifications/digests.
model Follow {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  leagueId String?
  league   League? @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, teamId])
  @@unique([userId, tenantId])
  @@unique([userId, leagueId])
  @@index([userId])
  @@index([teamId])
  @@index([tenantId])
  @@index([leagueId])
}

// Parental media consent (docs/public-site-content-plan.md §5). GRANTED also
// opts the player INTO full names on public surfaces (owner decision §11.1);
// otherwise public pages show "First L." — participants see full names.
enum MediaConsent {
  UNSET
  GRANTED
  DENIED
}

// ============================================
// REVIEWS & RATINGS (v1+)
// ============================================

model Review {
  id String @id @default(uuid())

  reviewerId String
  reviewer   User   @relation("ReviewsWritten", fields: [reviewerId], references: [id])

  // Target (one of these)
  tenantId String? // Review of club
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  leagueId String? // Review of league
  league   League? @relation(fields: [leagueId], references: [id])

  revieweeId String? // Review of a specific user (coach/staff/referee)
  reviewee   User?   @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  // Content
  rating  Int // 1-5
  title   String?
  content String? @db.Text

  status ReviewStatus @default(PUBLISHED)

  // Moderation
  flaggedAt      DateTime?
  moderatedAt    DateTime?
  moderatorNotes String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([leagueId])
  @@index([reviewerId])
  @@index([revieweeId])
  @@index([status])
}

model ReviewInvite {
  id       String @id @default(uuid())
  seasonId String
  season   Season @relation(fields: [seasonId], references: [id])
  tenantId String
  tenant   Tenant @relation("ReviewInvites", fields: [tenantId], references: [id])
  userId   String
  user     User   @relation("ReviewInvites", fields: [userId], references: [id])

  sentAt    DateTime  @default(now())
  expiresAt DateTime
  usedAt    DateTime?

  @@unique([seasonId, tenantId, userId])
  @@index([userId, expiresAt])
  @@index([tenantId])
}

// Withdrawals need the other party's sign-off (owner 2026-07-18): installment
// commitments make unilateral exits wrong. Clubs request out of a league
// season (league approves); parents request a child's release from a roster
// (club approves). League-side direct withdrawal stays — running the league
// is their right; SELF-withdrawal is what goes through here.
enum WithdrawalType {
  CLUB_FROM_LEAGUE
  PLAYER_FROM_TEAM
}

enum WithdrawalRequestStatus {
  PENDING
  APPROVED
  DECLINED
  CANCELLED
}

model WithdrawalRequest {
  id     String                  @id @default(uuid())
  type   WithdrawalType
  status WithdrawalRequestStatus @default(PENDING)
  reason String

  requestedById String
  requestedBy   User   @relation("WithdrawalRequestsMade", fields: [requestedById], references: [id])

  // CLUB_FROM_LEAGUE
  submissionId String?
  submission   TeamSubmission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  // PLAYER_FROM_TEAM
  teamPlayerId String?
  teamPlayer   TeamPlayer? @relation(fields: [teamPlayerId], references: [id], onDelete: Cascade)

  decidedById  String?
  decidedBy    User?     @relation("WithdrawalRequestsDecided", fields: [decidedById], references: [id])
  decidedAt    DateTime?
  decisionNote String?

  createdAt DateTime @default(now())

  @@index([submissionId])
  @@index([teamPlayerId])
  @@index([status])
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  FLAGGED
  REMOVED
}

// ============================================
// STAFF INVITATIONS & NOTIFICATIONS
// ============================================

model StaffInvitation {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Who sent it
  invitedById String
  invitedBy   User   @relation("SentInvitations", fields: [invitedById], references: [id])

  // Who it's for
  invitedUserId String?
  invitedUser   User?   @relation("ReceivedInvitations", fields: [invitedUserId], references: [id])
  invitedEmail  String

  role        Role
  teamId      String?
  designation CoachDesignation? // carried through on accept
  message     String? @db.Text

  type   InvitationType
  status InvitationStatus @default(PENDING)

  // Lazy expiry (checked on access, no cron) — stale PENDING invites used to
  // block re-inviting the same person forever. Null = legacy rows, never expire.
  expiresAt DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  respondedAt DateTime?

  @@index([tenantId])
  @@index([invitedUserId])
  @@index([invitedEmail])
  @@index([status])
}

enum InvitationType {
  INVITE
  REQUEST
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  EXPIRED
}

// Invite-a-player-by-email (Gap G3). Mirrors StaffInvitation: the club sends
// an invite to an email address; if a matching account exists it attaches
// immediately, otherwise the signup route auto-attaches it (same mechanism as
// staff invites). Accepting converts the invitation into a real Offer for a
// chosen child (parent) or the invitee's own player record (13+).
model PlayerInvitation {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // Who sent it
  invitedById String
  invitedBy   User   @relation("SentPlayerInvitations", fields: [invitedById], references: [id])

  // Who it's for (userId attached at creation for existing accounts, or by
  // the signup route once the recipient registers)
  invitedUserId String?
  invitedUser   User?   @relation("ReceivedPlayerInvitations", fields: [invitedUserId], references: [id])
  invitedEmail  String
  playerName    String? // free text: who the invite is about ("your son Marcus")
  message       String? @db.Text

  // Offer terms resolved when the invitation is accepted
  templateId String?
  template   OfferTemplate? @relation(fields: [templateId], references: [id])
  seasonFee  Decimal?       @db.Decimal(10, 2) // overrides template when set

  status    InvitationStatus @default(PENDING)
  expiresAt DateTime

  // The offer created on acceptance
  offerId String? @unique
  offer   Offer?  @relation(fields: [offerId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  respondedAt DateTime?

  @@index([tenantId])
  @@index([teamId])
  @@index([invitedUserId, status])
  @@index([invitedEmail])
}

model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    String
  title   String
  message String  @db.Text
  link    String?

  isRead Boolean @default(false)

  referenceId   String?
  referenceType String?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ============================================
// AUDIT & LOGGING
// ============================================

model AuditLog {
  id String @id @default(uuid())

  userId   String
  user     User   @relation(fields: [userId], references: [id])
  userRole Role

  action     String // CREATE, UPDATE, DELETE, etc.
  resource   String // Team, Payment, etc.
  resourceId String

  tenantId  String?
  ipAddress String
  userAgent String

  changes  Json?
  metadata Json?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([tenantId, createdAt])
  @@index([resource, resourceId])
}

// ============================================
// HOUSE LEAGUES (club programs)
// ============================================

model HouseLeague {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String? @db.Text
  details     String? @db.Text // What's included, program details

  ageGroups String // Comma-separated: "U8,U10,U12"
  gender    Gender?
  season    String? // "Fall 2026", "Winter 2026-27"

  // Schedule
  startDate  DateTime
  endDate    DateTime
  daysOfWeek String // "Saturday" or "Monday,Wednesday"
  startTime  String // "10:00"
  endTime    String // "12:00"
  location   String

  // Pricing
  fee Decimal @db.Decimal(10, 2)

  // Capacity
  maxParticipants Int?

  // What's included
  includesUniform Boolean @default(false)
  includesJersey  Boolean @default(false)
  includesBall    Boolean @default(false)
  includesMedal   Boolean @default(false)

  isPublished Boolean @default(false)

  // Relationships
  signups HouseLeagueSignup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([isPublished])
  @@index([startDate])
}

model HouseLeagueSignup {
  id            String      @id @default(uuid())
  houseLeagueId String
  houseLeague   HouseLeague @relation(fields: [houseLeagueId], references: [id], onDelete: Cascade)

  userId String // Parent
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  status HouseLeagueSignupStatus @default(REGISTERED)

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([houseLeagueId, playerId]) // One signup per player per league
  @@index([houseLeagueId])
  @@index([userId])
  @@index([playerId])
}

enum HouseLeagueSignupStatus {
  REGISTERED
  CONFIRMED
  WAITLISTED
  CANCELLED
}

// ============================================
// CAMPS (March break, holiday, summer, multi-week)
// ============================================

model Camp {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String? @db.Text
  details     String? @db.Text // What's included, daily activities, etc.

  campType CampType
  ageGroup String
  gender   Gender?

  // Dates
  startDate      DateTime
  endDate        DateTime
  dailyStartTime String // "09:00"
  dailyEndTime   String // "16:00"
  location       String

  // Multi-week pricing
  numberOfWeeks Int      @default(1)
  weeklyFee     Decimal  @db.Decimal(10, 2) // Price per single week
  fullCampFee   Decimal? @db.Decimal(10, 2) // Discounted price for all weeks

  maxParticipants Int?

  // What's included
  includesLunch  Boolean @default(false)
  includesSnacks Boolean @default(false)
  includesJersey Boolean @default(false)
  includesBall   Boolean @default(false)

  isPublished Boolean @default(false)

  signups CampSignup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([campType])
  @@index([isPublished])
  @@index([startDate])
}

enum CampType {
  MARCH_BREAK
  HOLIDAY
  SUMMER
  WEEKLY
}

model CampSignup {
  id     String @id @default(uuid())
  campId String
  camp   Camp   @relation(fields: [campId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  weeksSelected Int     @default(1)
  totalFee      Decimal @db.Decimal(10, 2)

  status CampSignupStatus @default(REGISTERED)
  notes  String?          @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campId, playerId])
  @@index([campId])
  @@index([userId])
  @@index([playerId])
}

enum CampSignupStatus {
  REGISTERED
  CONFIRMED
  WAITLISTED
  CANCELLED
}

// ============================================
// PLATFORM SETTINGS (singleton)
// ============================================

model PlatformSettings {
  id               String   @id @default("default")
  enabledCountries String[] // ISO codes: ["US", "CA"]

  // Platform-wide payment policy — the defaults every merchant inherits.
  // Per-merchant PaymentConfig rows override field-by-field (null = inherit).
  payOfflineAllowed         Boolean    @default(true)
  payConnectAllowed         Boolean    @default(true)
  payPlatformCollectAllowed Boolean    @default(false)
  payDefaultOnlineMode      OnlineMode @default(NONE)
  payPlatformFeeBps         Int        @default(0)
  payPlatformFeeFlat        Decimal    @default(0) @db.Decimal(10, 2)

  // Global search-engine switch (owner-controlled from admin settings).
  // OFF = site-wide noindex + robots disallow + empty sitemap, regardless of
  // per-page rules. Flip ON at go-live (docs/roadmap/seo-strategy.md §9).
  seoIndexingEnabled Boolean @default(false)

  // Platform theme palette (admin-switchable; Energy Pass 2026-07-15).
  // One of design-tokens' PALETTES ids ("hardwood" | "fastbreak" | "primetime").
  // Unknown values fail open to hardwood. Future custom palettes will add a
  // JSON override column beside this.
  themePalette String @default("hardwood")
  // Review invites (owner 2026-07-18): platform default, clubs may override
  reviewInvitePolicy String @default("AUTO") // AUTO | OFF
  reviewWindowDays   Int    @default(30)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// First-party view tracking for PUBLIC pages (SEO analytics). One row per
/// server render of a tracked page; `source` classifies the referrer so we
/// can report organic-search landings per club — the "your page got N Google
/// visits without you doing anything" claim-pitch number.
model PublicPageView {
  id         String   @id @default(uuid())
  path       String
  entityType String // CLUB | CAMP | TRYOUT | HOUSE_LEAGUE | TOURNAMENT | NEWS
  entityId   String?
  tenantId   String? // owning club (denormalized for per-club reports)
  source     String // ORGANIC | DIRECT | REFERRAL | INTERNAL | BOT
  refHost    String?
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([entityType, createdAt])
  @@index([source, createdAt])
}

// ============================================
// CLUB CLAIMS (for unclaimed clubs)
// ============================================

model ClubClaim {
  id String @id @default(uuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // v2 (owner 2026-07-18): claims start ANONYMOUS — ownership binds to a User
  // at completion, never to a contact point. Null until the completion token
  // is redeemed (v1 signed-in claims still set it up front).
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status ClaimStatus @default(PENDING)

  // Verification
  verificationCode   String? // 6-digit code sent to the club's contact ON FILE
  verificationSentAt DateTime?
  verifiedAt         DateTime?
  attempts           Int       @default(0) // wrong-code counter (cap enforced in code)

  // v2 verification channel: EMAIL | SMS | PROOF (paper-proof -> admin review)
  method       String?
  contactPoint String? // the exact email/phone the code went to
  // paper-proof path: how we reach the claimer (no account yet)
  claimantEmail String?
  proofNote     String? @db.Text

  // Reservation + binding: a verified-but-unregistered claim holds the club
  // (completionExpiresAt ~14d). Redeeming the token binds claim -> User.
  completionToken     String?   @unique
  completionExpiresAt DateTime?

  // Claim-time corrections to the club's info, applied at completion
  corrections Json?

  message String? @db.Text // Optional message from claimant

  reviewedById String? // Admin who approved/rejected
  reviewNote   String?   @db.Text
  reviewedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId]) // one claim per user per club (NULL userId = anonymous, repeatable)
  @@index([tenantId])
  @@index([userId])
  @@index([status])
}

enum ClaimStatus {
  PENDING
  EMAIL_SENT
  EMAIL_VERIFIED
  VERIFIED_UNBOUND
  APPROVED
  REJECTED
  EXPIRED
}

// ============================================
// TOURNAMENTS (weekend / short-format events)
// ============================================

model Tournament {
  id          String  @id @default(uuid())
  name        String
  description String? @db.Text

  // Owner (the user who created it — club owner or league owner)
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  // Optional club association (null if created by a league owner)
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Location
  city    String
  state   String?
  country String  @default("CA")

  // Dates
  startDate            DateTime
  endDate              DateTime
  registrationDeadline DateTime?

  // Pricing
  teamFee  Decimal @db.Decimal(10, 2)
  currency String  @default("CAD")

  // Tournament details
  gamesGuaranteed   Int    @default(3)
  gameSlotMinutes   Int    @default(60)
  gameLengthMinutes Int    @default(40)
  gamePeriods       String @default("HALVES") // "HALVES" or "QUARTERS"

  // Playoffs
  playoffFormat String? // "SINGLE_ELIMINATION", "DOUBLE_ELIMINATION", "ROUND_ROBIN"

  // Status
  status TournamentStatus @default(DRAFT)

  // Relationships
  divisions TournamentDivision[]
  teams     TournamentTeam[]
  venues    TournamentVenue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([ownerId])
  @@index([status])
  @@index([startDate])
}

enum TournamentStatus {
  DRAFT
  REGISTRATION
  REGISTRATION_CLOSED
  FINALIZED
  IN_PROGRESS
  COMPLETED
}

model TournamentDivision {
  id           String     @id @default(uuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  name     String // "U12 Boys"
  ageGroup String // "U12"
  gender   Gender?
  maxTeams Int? // Cap per division

  teams TournamentTeam[]

  @@index([tournamentId])
}

model TournamentTeam {
  id           String     @id @default(uuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  divisionId String?
  division   TournamentDivision? @relation(fields: [divisionId], references: [id])

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  status          TournamentTeamStatus @default(PENDING)
  registrationFee Decimal?             @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  @@unique([tournamentId, teamId])
  @@index([tournamentId])
  @@index([teamId])
}

enum TournamentTeamStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

model TournamentVenue {
  id           String     @id @default(uuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id])

  isPrimary Boolean @default(false)

  @@unique([tournamentId, venueId])
  @@index([tournamentId])
}

// ============================================
// COMMUNICATIONS & CONSENT (CASL) — 2026-07-09
// ============================================

enum ConsentScope {
  PLATFORM
  TENANT
  LEAGUE
}

enum ConsentStatus {
  EXPRESS // explicit checkbox — durable until withdrawn
  IMPLIED // existing business relationship (registration/purchase) — ~2y window
  WITHDRAWN
}

/// Marketing-email consent, scoped PER SENDING ORG (CASL: the sender is the
/// club/league, not the platform). Transactional email is out of scope here.
/// Bare ids (no FK relations) by design — consent must survive org deletion.
model CommunicationConsent {
  id     String @id @default(uuid())
  userId String

  scope    ConsentScope
  tenantId String? // set when scope=TENANT
  leagueId String? // set when scope=LEAGUE

  status ConsentStatus
  source String // e.g. "registration:camp:<id>" | "checkbox:signup" | "unsubscribe-link"

  /// Rolls forward on each new registration — anchors the implied-consent window.
  lastEngagedAt DateTime @default(now())
  withdrawnAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, scope, tenantId, leagueId])
  @@index([userId])
  @@index([tenantId])
  @@index([leagueId])
}

/// Audit log for every marketing/broadcast send (composer ships phase 3, the
/// log exists from day one so nothing ever sends unrecorded).
model MessageLog {
  id       String  @id @default(uuid())
  senderId String // user who triggered the send
  scope    ConsentScope
  tenantId String?
  leagueId String?

  audience       String // computed-audience descriptor, e.g. "team:<id>:families"
  subject        String
  body           String @db.Text
  recipientCount Int
  suppressedCount Int   @default(0) // recipients skipped for lack of consent

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([leagueId])
  @@index([senderId])
}
