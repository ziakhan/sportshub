// Youth Basketball Hub - Complete Prisma Schema
// Includes all MVP models with recommended enhancements

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin", "darwin-arm64", "linux-musl-openssl-3.0.x", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE ENTITIES
// ============================================

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  firstName     String?
  lastName      String?
  phoneNumber   String?
  avatarUrl     String?
  city          String?
  state         String?
  country       String   @default("CA") // ISO 3166-1 alpha-2

  // Soft Delete (Recommended Addition)
  status        UserStatus @default(ACTIVE)
  deletedAt     DateTime?

  // Onboarding
  onboardedAt   DateTime?

  // Relationships
  roles         UserRole[]
  players       Player[]  @relation("ParentPlayers")
  tryoutSignups TryoutSignup[]
  paymentsAsPayer Payment[] @relation("PayerPayments")
  paymentsAsPayee Payment[] @relation("PayeePayments")
  auditLogs     AuditLog[]
  reviews       Review[] @relation("ReviewsWritten")
  reviewsReceived Review[] @relation("ReviewsReceived")
  announcements Announcement[]
  sentInvitations     StaffInvitation[] @relation("SentInvitations")
  receivedInvitations StaffInvitation[] @relation("ReceivedInvitations")
  notifications       Notification[]
  clubClaims          ClubClaim[]
  houseLeagueSignups  HouseLeagueSignup[]
  campSignups         CampSignup[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([email])
  @@index([status])
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

model UserRole {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  role          Role

  // Scope (nullable based on role)
  tenantId      String?
  tenant        Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  teamId        String?
  team          Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  leagueId      String?
  league        League?  @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  gameId        String?  // For temporary scorekeeper role
  game          Game?    @relation(fields: [gameId], references: [id], onDelete: Cascade)

  designation   String?   // "HeadCoach", "AssistantCoach" — for Coach roles on a team
  expiresAt     DateTime? // For temporary roles

  createdAt     DateTime @default(now())

  @@unique([userId, role, tenantId, teamId, leagueId, gameId])
  @@index([userId])
  @@index([tenantId])
  @@index([teamId])
  @@index([leagueId])
}

enum Role {
  ClubOwner
  ClubManager
  Staff
  TeamManager
  Scorekeeper
  LeagueOwner
  LeagueManager
  Parent
  Player
  Referee
  PlatformAdmin
}

// ============================================
// MULTI-TENANCY
// ============================================

model Tenant {
  id            String   @id @default(uuid())
  slug          String   @unique
  name          String
  description   String?  @db.Text
  phoneNumber   String?
  contactEmail  String?
  address       String?
  city          String?
  state         String?
  zipCode       String?
  country       String   @default("US")  // ISO 3166-1 alpha-2
  currency      String   @default("CAD") // ISO 4217
  website       String?
  customDomain  String?  @unique

  // Timezone (Recommended Addition)
  timezone      String   @default("America/New_York")

  // Stripe
  stripeAccountId String? @unique
  stripeAccountStatus String? // active, pending, restricted

  // Subscription
  plan          TenantPlan   @default(FREE)
  planExpiresAt DateTime?
  status        TenantStatus @default(ACTIVE)

  // Relationships
  branding      TenantBranding?
  features      TenantFeatures?
  teams         Team[]
  staff         UserRole[]
  tryouts       Tryout[]
  practices     Practice[]
  venues        Venue[]
  announcements Announcement[]
  payments      Payment[] @relation("TenantPayments")
  reviews       Review[]
  staffInvitations StaffInvitation[]
  clubClaims    ClubClaim[]
  houseLeagues  HouseLeague[]
  camps         Camp[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([slug])
  @@index([customDomain])
}

enum TenantPlan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  UNCLAIMED
}

model TenantBranding {
  id            String   @id @default(uuid())
  tenantId      String   @unique
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  logoUrl       String?
  faviconUrl    String?
  primaryColor  String   @default("#1a73e8")
  secondaryColor String  @default("#34a853")
  accentColor   String   @default("#fbbc04")
  fontFamily    String   @default("Inter")
  customCss     String?  @db.Text

  emailLogoUrl  String?
  emailFooter   String?  @db.Text

  updatedAt     DateTime @updatedAt
}

model TenantFeatures {
  id                String   @id @default(uuid())
  tenantId          String   @unique
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  enableTournaments Boolean  @default(false)
  enableReviews     Boolean  @default(true)
  enableChat        Boolean  @default(false)
  enableAnalytics   Boolean  @default(false)

  maxTeams          Int      @default(10)
  maxStaff          Int      @default(5)
  maxVenues         Int      @default(3)
}

// ============================================
// TEAMS & PLAYERS
// ============================================

model Team {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name          String
  ageGroup      String   // U10, U12, U14, etc.
  gender        Gender?
  season        String?  // "Spring 2026"
  description   String?  @db.Text

  // Relationships
  players       TeamPlayer[]
  staff         UserRole[]
  leagues       LeagueTeam[]
  homeGames     Game[]   @relation("HomeTeam")
  awayGames     Game[]   @relation("AwayTeam")
  practices     Practice[]
  announcements Announcement[]
  offers        Offer[]
  offerTemplates OfferTemplate[]
  tryouts       Tryout[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([ageGroup])
}

enum Gender {
  MALE
  FEMALE
  COED
}

model Player {
  id            String   @id @default(uuid())

  // Personal Info
  firstName     String
  lastName      String
  dateOfBirth   DateTime
  gender        Gender
  jerseyNumber  String?
  height        String?   // e.g. "5'6"
  weight        Int?      // in pounds
  position      String?   // e.g. "Point Guard", "Center"

  // COPPA Compliance (Recommended Addition)
  isMinor       Boolean  @default(false) // Age < 13
  parentalConsentGiven Boolean? // Required if isMinor = true
  consentGivenAt DateTime?
  canLogin      Boolean  @default(false) // Only true if 13+

  // Parent/Guardian
  parentId      String
  parent        User     @relation("ParentPlayers", fields: [parentId], references: [id], onDelete: Cascade)

  // Relationships
  teams         TeamPlayer[]
  stats         PlayerStat[]
  offers        Offer[]
  houseLeagueSignups HouseLeagueSignup[]
  campSignups        CampSignup[]
  leagueRosterEntries LeagueRosterPlayer[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([parentId])
  @@index([isMinor])
}

model TeamPlayer {
  id            String   @id @default(uuid())
  teamId        String
  team          Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  playerId      String
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  jerseyNumber  Int?
  uniformSize   String?  // YS, YM, YL, AS, AM, AL, AXL
  shoeSize      String?  // e.g. "7", "8.5"
  tracksuitSize String?  // YS, YM, YL, AS, AM, AL, AXL

  status        TeamPlayerStatus @default(ACTIVE)
  joinedAt      DateTime @default(now())
  leftAt        DateTime?

  @@unique([teamId, playerId])
  @@index([teamId])
  @@index([playerId])
}

enum TeamPlayerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ============================================
// REFEREE PROFILES (Recommended Addition)
// ============================================

model RefereeProfile {
  id            String   @id @default(uuid())
  userId        String   @unique

  // Certifications
  certificationLevel String? // "Level 1", "Level 2", etc.
  certificationExpiry DateTime?

  // Availability
  availableRegions String[] // ["California", "Nevada"]

  // Fee
  standardFee   Decimal  @db.Decimal(10, 2)

  // Stripe Connect
  stripeAccountId String? @unique
  stripeAccountStatus String?

  // Stats
  gamesRefereed Int      @default(0)
  averageRating Decimal? @db.Decimal(3, 2)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

// ============================================
// TRYOUTS & OFFERS
// ============================================

model Tryout {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  teamId        String?
  team          Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)

  title         String
  description   String?  @db.Text
  ageGroup      String
  gender        Gender?

  location      String
  scheduledAt   DateTime
  duration      Int?     // minutes

  fee           Decimal  @db.Decimal(10, 2)
  maxParticipants Int?

  isPublished   Boolean  @default(false)
  isPublic      Boolean  @default(true)

  // Relationships
  signups       TryoutSignup[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([teamId])
  @@index([scheduledAt])
  @@index([isPublished, isPublic])
}

model TryoutSignup {
  id            String   @id @default(uuid())
  tryoutId      String
  tryout        Tryout   @relation(fields: [tryoutId], references: [id], onDelete: Cascade)

  userId        String   // Parent
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  playerName    String
  playerAge     Int
  playerGender  Gender

  status        TryoutSignupStatus @default(PENDING)
  paymentId     String?  @unique
  payment       Payment? @relation(fields: [paymentId], references: [id])

  notes         String?  @db.Text

  // Relationships
  offers        Offer[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tryoutId, userId, playerName])
  @@index([tryoutId])
  @@index([userId])
}

enum TryoutSignupStatus {
  PENDING
  PAID
  CONFIRMED
  CANCELLED
  OFFERED
}

model OfferTemplate {
  id            String   @id @default(uuid())
  teamId        String
  team          Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  name          String   // e.g. "Standard Package", "Premium Package"

  seasonFee     Decimal  @db.Decimal(10, 2)
  installments  Int      @default(1)
  practiceSessions Int   @default(0)

  // Included items
  includesBall      Boolean @default(false) // basketball
  includesBag       Boolean @default(false) // equipment bag
  includesShoes     Boolean @default(false)
  includesUniform   Boolean @default(false) // shirt + shorts
  includesTracksuit Boolean @default(false)

  isActive      Boolean  @default(true)

  offers        Offer[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([teamId])
}

model Offer {
  id            String   @id @default(uuid())
  teamId        String
  team          Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  playerId      String
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  tryoutSignupId String?
  tryoutSignup  TryoutSignup? @relation(fields: [tryoutSignupId], references: [id])

  templateId    String?
  template      OfferTemplate? @relation(fields: [templateId], references: [id])

  status        OfferStatus @default(PENDING)

  // Offer details (copied from template, tweakable per offer)
  seasonFee     Decimal  @db.Decimal(10, 2)
  installments  Int      @default(1)
  practiceSessions Int   @default(0)

  // Included items
  includesBall      Boolean @default(false)
  includesBag       Boolean @default(false)
  includesShoes     Boolean @default(false)
  includesUniform   Boolean @default(false)
  includesTracksuit Boolean @default(false)

  message       String?  @db.Text
  expiresAt     DateTime

  // Filled on acceptance by parent/player
  uniformSize   String?  // YS, YM, YL, AS, AM, AL, AXL
  shoeSize      String?  // e.g. "7", "8.5"
  tracksuitSize String?  // YS, YM, YL, AS, AM, AL, AXL
  jerseyPref1   Int?     // First choice jersey number
  jerseyPref2   Int?     // Second choice jersey number
  jerseyPref3   Int?     // Third choice jersey number

  respondedAt   DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([teamId])
  @@index([playerId])
  @@index([tryoutSignupId])
  @@index([templateId])
  @@index([status])
}

enum OfferStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

// ============================================
// LEAGUES & GAMES
// ============================================

model League {
  id            String   @id @default(uuid())
  name          String
  description   String?  @db.Text
  season        String   // "Fall 2026", "Winter 2026-27"

  ownerId       String

  // Season dates
  startDate     DateTime?
  endDate       DateTime?
  registrationDeadline DateTime? // Clubs must submit by this date

  // Age Group Cutoff
  ageGroupCutoffDate DateTime? // e.g., "Aug 31, 2026"

  // Pricing
  teamFee       Decimal? @db.Decimal(10, 2) // Per team registration fee
  currency      String   @default("CAD")

  // Season details
  gamesGuaranteed Int?    // Regular season games guaranteed
  gamesPerSession Int     @default(1) // Games per weekend/session

  // Game format
  gameSlotMinutes Int     @default(90)  // Schedule slot duration (including warmup, breaks)
  gameLengthMinutes Int   @default(40)  // Actual game length
  gamePeriods     String  @default("HALVES") // "HALVES" (2x) or "QUARTERS" (4x)

  // Playoffs (optional — can be defined later)
  playoffFormat String?  // "SINGLE_ELIMINATION", "DOUBLE_ELIMINATION", "ROUND_ROBIN"
  playoffTeams  Int?     // Number of teams that advance to playoffs

  // Status
  leagueStatus  LeagueSeasonStatus @default(DRAFT)

  // Stripe
  stripeAccountId String? @unique

  // Relationships
  divisions     LeagueDivision[]
  teams         LeagueTeam[]
  games         Game[]
  staff         UserRole[]
  reviews       Review[]
  sessions      LeagueSession[]
  leagueVenues  LeagueVenue[]
  rosters       LeagueRoster[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([season])
  @@index([leagueStatus])
}

enum LeagueSeasonStatus {
  DRAFT            // League admin building the season
  REGISTRATION     // Published, clubs can register teams
  REGISTRATION_CLOSED // Deadline passed, reviewing submissions
  FINALIZED        // Rosters locked, ready for scheduling
  IN_PROGRESS      // Games being played
  COMPLETED        // Season over
}

model LeagueDivision {
  id            String   @id @default(uuid())
  leagueId      String
  league        League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  name          String   // "U14 Boys Division A"
  ageGroup      String   // "U14", "Junior", "Senior"
  gender        Gender?
  tier          Int      @default(1) // 1 = top division, 2 = second, etc.

  teams         LeagueTeam[]

  @@index([leagueId])
}

model LeagueTeam {
  id            String   @id @default(uuid())
  leagueId      String
  league        League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  divisionId    String?
  division      LeagueDivision? @relation(fields: [divisionId], references: [id])

  teamId        String
  team          Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  status        LeagueTeamStatus @default(PENDING)
  registrationFee Decimal? @db.Decimal(10, 2)
  paymentId     String?  @unique
  payment       Payment? @relation(fields: [paymentId], references: [id])

  // Frozen roster for this league
  roster        LeagueRoster?

  createdAt     DateTime @default(now())

  @@unique([leagueId, teamId])
  @@index([leagueId])
  @@index([teamId])
}

enum LeagueTeamStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

// Frozen roster snapshot for a team in a league
model LeagueRoster {
  id            String   @id @default(uuid())
  leagueId      String
  league        League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  leagueTeamId  String   @unique
  leagueTeam    LeagueTeam @relation(fields: [leagueTeamId], references: [id], onDelete: Cascade)

  isLocked      Boolean  @default(false) // Locked once league finalizes

  players       LeagueRosterPlayer[]

  submittedAt   DateTime?
  lockedAt      DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([leagueId])
}

model LeagueRosterPlayer {
  id            String   @id @default(uuid())
  rosterId      String
  roster        LeagueRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  playerId      String
  player        Player   @relation(fields: [playerId], references: [id])

  jerseyNumber  Int?
  position      String?  // Position for this league

  createdAt     DateTime @default(now())

  @@unique([rosterId, playerId])
  @@index([rosterId])
  @@index([playerId])
}

// A session is a multi-day weekend (e.g., Fri-Sat-Sun)
model LeagueSession {
  id            String   @id @default(uuid())
  leagueId      String
  league        League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  label         String?  // "Week 1", "Session 3", etc.

  venueId       String?
  venue         Venue?   @relation(fields: [venueId], references: [id])

  // Session days (each day has its own date + times)
  days          LeagueSessionDay[]

  createdAt     DateTime @default(now())

  @@index([leagueId])
}

// Individual day within a session (e.g., Friday of Week 1)
model LeagueSessionDay {
  id            String   @id @default(uuid())
  sessionId     String
  session       LeagueSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  date          DateTime // The specific date
  startTime     String   // "18:00" (6pm Friday) or "09:00" (9am Saturday)
  endTime       String   // "21:00" or "17:00"

  @@index([sessionId])
  @@index([date])
}

// Venues assigned to a league
model LeagueVenue {
  id            String   @id @default(uuid())
  leagueId      String
  league        League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  venueId       String
  venue         Venue    @relation(fields: [venueId], references: [id])

  isPrimary     Boolean  @default(false)

  @@unique([leagueId, venueId])
  @@index([leagueId])
}

model Game {
  id            String   @id @default(uuid())
  leagueId      String?  // Null for exhibition games
  league        League?  @relation(fields: [leagueId], references: [id])

  homeTeamId    String
  homeTeam      Team     @relation("HomeTeam", fields: [homeTeamId], references: [id])

  awayTeamId    String
  awayTeam      Team     @relation("AwayTeam", fields: [awayTeamId], references: [id])

  venueId       String?
  venue         Venue?   @relation(fields: [venueId], references: [id])

  scheduledAt   DateTime
  duration      Int      @default(90) // minutes
  status        GameStatus @default(SCHEDULED)

  // Scoring
  homeScore     Int?
  awayScore     Int?

  // Relationships
  events        GameEvent[]
  stats         PlayerStat[]
  scorekeepers  UserRole[]

  finalizedAt   DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([leagueId])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([scheduledAt])
  @@index([status])
}

enum GameStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
  POSTPONED
}

model GameEvent {
  id            String   @id @default(uuid())
  gameId        String
  game          Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  eventType     GameEventType
  teamId        String   // Team that scored/fouled
  playerId      String?  // Player involved

  points        Int?     // For SCORE events
  quarter       Int?     // 1-4
  timestamp     DateTime @default(now())

  metadata      Json?    // Additional event data

  @@index([gameId])
  @@index([teamId])
  @@index([playerId])
}

enum GameEventType {
  SCORE_2PT
  SCORE_3PT
  SCORE_FT
  REBOUND
  ASSIST
  STEAL
  BLOCK
  TURNOVER
  FOUL
  TIMEOUT
  SUBSTITUTION
}

model PlayerStat {
  id            String   @id @default(uuid())
  gameId        String
  game          Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  playerId      String
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  // Stats (Auto-calculated from GameEvents)
  points        Int      @default(0)
  rebounds      Int      @default(0)
  assists       Int      @default(0)
  steals        Int      @default(0)
  blocks        Int      @default(0)
  turnovers     Int      @default(0)
  fouls         Int      @default(0)

  minutesPlayed Int?

  @@unique([gameId, playerId])
  @@index([gameId])
  @@index([playerId])
}

// ============================================
// VENUES & PRACTICES
// ============================================

model Venue {
  id            String   @id @default(uuid())
  tenantId      String?  // Optional — venues are global
  tenant        Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  name          String
  address       String
  city          String
  state         String
  zipCode       String?
  country       String   @default("CA")
  phoneNumber   String?

  // Google Places
  placeId       String?  @unique // Google Place ID for dedup
  latitude      Float?
  longitude     Float?

  capacity      Int?
  notes         String?  @db.Text

  games         Game[]
  practices     Practice[]
  leagueSessions LeagueSession[]
  leagueVenues  LeagueVenue[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([city])
  @@index([name])
}

model Practice {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  teamId        String
  team          Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  venueId       String?
  venue         Venue?   @relation(fields: [venueId], references: [id])

  scheduledAt   DateTime
  duration      Int      // minutes

  notes         String?  @db.Text
  status        PracticeStatus @default(SCHEDULED)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([teamId])
  @@index([scheduledAt])
}

enum PracticeStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

// ============================================
// PAYMENTS (Enhanced with Installments)
// ============================================

model Payment {
  id            String   @id @default(uuid())

  // Stripe
  stripePaymentIntentId String? @unique
  stripeChargeId        String? @unique

  // Parties
  payerId       String
  payer         User     @relation("PayerPayments", fields: [payerId], references: [id])

  payeeId       String?  // Club/League owner
  payee         User?    @relation("PayeePayments", fields: [payeeId], references: [id])

  tenantId      String?  // If club payment
  tenant        Tenant?  @relation("TenantPayments", fields: [tenantId], references: [id])

  // Payment Details
  amount        Decimal  @db.Decimal(10, 2)
  currency      String   @default("usd")
  platformFee   Decimal? @db.Decimal(10, 2)

  status        PaymentStatus @default(PENDING)

  // Installments (Recommended Addition)
  dueDate       DateTime? // For installment payments
  installmentNumber Int?  // 1, 2, 3, 4
  relatedOfferId String?  // Link installments together

  // Context
  paymentType   PaymentType
  description   String?

  // Relationships
  tryoutSignup  TryoutSignup?
  leagueTeam    LeagueTeam?

  // Refund
  refundedAt    DateTime?
  refundAmount  Decimal? @db.Decimal(10, 2)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([payerId])
  @@index([payeeId])
  @@index([tenantId])
  @@index([status])
  @@index([paymentType])
  @@index([dueDate])
  @@index([relatedOfferId])
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  DISPUTED
}

enum PaymentType {
  TRYOUT_FEE
  SEASON_FEE
  LEAGUE_FEE
  TOURNAMENT_FEE
  REFEREE_FEE
  OTHER
}

// ============================================
// COMMUNICATIONS
// ============================================

model Announcement {
  id            String   @id @default(uuid())
  tenantId      String?
  tenant        Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  teamId        String?
  team          Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  authorId      String
  author        User     @relation(fields: [authorId], references: [id])

  title         String
  content       String   @db.Text

  isPinned      Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([teamId])
  @@index([createdAt])
}

// ============================================
// REVIEWS & RATINGS (v1+)
// ============================================

model Review {
  id            String   @id @default(uuid())

  reviewerId    String
  reviewer      User     @relation("ReviewsWritten", fields: [reviewerId], references: [id])

  // Target (one of these)
  tenantId      String?  // Review of club
  tenant        Tenant?  @relation(fields: [tenantId], references: [id])

  leagueId      String?  // Review of league
  league        League?  @relation(fields: [leagueId], references: [id])

  revieweeId    String?  // Review of a specific user (coach/staff/referee)
  reviewee      User?    @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  // Content
  rating        Int      // 1-5
  title         String?
  content       String?  @db.Text

  status        ReviewStatus @default(PUBLISHED)

  // Moderation
  flaggedAt     DateTime?
  moderatedAt   DateTime?
  moderatorNotes String? @db.Text

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([leagueId])
  @@index([reviewerId])
  @@index([revieweeId])
  @@index([status])
}

enum ReviewStatus {
  PUBLISHED
  FLAGGED
  REMOVED
}

// ============================================
// STAFF INVITATIONS & NOTIFICATIONS
// ============================================

model StaffInvitation {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Who sent it
  invitedById   String
  invitedBy     User     @relation("SentInvitations", fields: [invitedById], references: [id])

  // Who it's for
  invitedUserId String?
  invitedUser   User?    @relation("ReceivedInvitations", fields: [invitedUserId], references: [id])
  invitedEmail  String

  role          Role
  teamId        String?
  designation   String?   // "HeadCoach", "AssistantCoach" — carried through on accept
  message       String?  @db.Text

  type          InvitationType
  status        InvitationStatus @default(PENDING)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  respondedAt   DateTime?

  @@index([tenantId])
  @@index([invitedUserId])
  @@index([invitedEmail])
  @@index([status])
}

enum InvitationType {
  INVITE
  REQUEST
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

model Notification {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type          String
  title         String
  message       String   @db.Text
  link          String?

  isRead        Boolean  @default(false)

  referenceId   String?
  referenceType String?

  createdAt     DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ============================================
// AUDIT & LOGGING
// ============================================

model AuditLog {
  id            String   @id @default(uuid())

  userId        String
  user          User     @relation(fields: [userId], references: [id])
  userRole      Role

  action        String   // CREATE, UPDATE, DELETE, etc.
  resource      String   // Team, Payment, etc.
  resourceId    String

  tenantId      String?
  ipAddress     String
  userAgent     String

  changes       Json?
  metadata      Json?

  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([tenantId, createdAt])
  @@index([resource, resourceId])
}

// ============================================
// HOUSE LEAGUES (club programs)
// ============================================

model HouseLeague {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name          String
  description   String?  @db.Text
  details       String?  @db.Text // What's included, program details

  ageGroup      String   // U8, U10, U12, etc.
  gender        Gender?
  season        String?  // "Fall 2026", "Winter 2026-27"

  // Schedule
  startDate     DateTime
  endDate       DateTime
  daysOfWeek    String   // "Saturday" or "Monday,Wednesday"
  startTime     String   // "10:00"
  endTime       String   // "12:00"
  location      String

  // Pricing
  fee           Decimal  @db.Decimal(10, 2)

  // Capacity
  maxParticipants Int?

  // What's included
  includesUniform   Boolean @default(false)
  includesJersey    Boolean @default(false)
  includesBall      Boolean @default(false)
  includesMedal     Boolean @default(false)

  isPublished   Boolean  @default(false)

  // Relationships
  signups       HouseLeagueSignup[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([isPublished])
  @@index([startDate])
}

model HouseLeagueSignup {
  id              String   @id @default(uuid())
  houseLeagueId   String
  houseLeague     HouseLeague @relation(fields: [houseLeagueId], references: [id], onDelete: Cascade)

  userId          String   // Parent
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  playerId        String
  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  status          HouseLeagueSignupStatus @default(REGISTERED)

  notes           String?  @db.Text

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([houseLeagueId, playerId]) // One signup per player per league
  @@index([houseLeagueId])
  @@index([userId])
  @@index([playerId])
}

enum HouseLeagueSignupStatus {
  REGISTERED
  CONFIRMED
  WAITLISTED
  CANCELLED
}

// ============================================
// CAMPS (March break, holiday, summer, multi-week)
// ============================================

model Camp {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name          String
  description   String?  @db.Text
  details       String?  @db.Text // What's included, daily activities, etc.

  campType      CampType
  ageGroup      String
  gender        Gender?

  // Dates
  startDate     DateTime
  endDate       DateTime
  dailyStartTime String  // "09:00"
  dailyEndTime   String  // "16:00"
  location      String

  // Multi-week pricing
  numberOfWeeks   Int     @default(1)
  weeklyFee       Decimal @db.Decimal(10, 2) // Price per single week
  fullCampFee     Decimal? @db.Decimal(10, 2) // Discounted price for all weeks

  maxParticipants Int?

  // What's included
  includesLunch    Boolean @default(false)
  includesSnacks   Boolean @default(false)
  includesJersey   Boolean @default(false)
  includesBall     Boolean @default(false)

  isPublished   Boolean  @default(false)

  signups       CampSignup[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([campType])
  @@index([isPublished])
  @@index([startDate])
}

enum CampType {
  MARCH_BREAK
  HOLIDAY
  SUMMER
  WEEKLY
}

model CampSignup {
  id            String   @id @default(uuid())
  campId        String
  camp          Camp     @relation(fields: [campId], references: [id], onDelete: Cascade)

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  playerId      String
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  weeksSelected Int      @default(1)
  totalFee      Decimal  @db.Decimal(10, 2)

  status        CampSignupStatus @default(REGISTERED)
  notes         String?  @db.Text

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([campId, playerId])
  @@index([campId])
  @@index([userId])
  @@index([playerId])
}

enum CampSignupStatus {
  REGISTERED
  CONFIRMED
  WAITLISTED
  CANCELLED
}

// ============================================
// PLATFORM SETTINGS (singleton)
// ============================================

model PlatformSettings {
  id                String   @id @default("default")
  enabledCountries  String[] // ISO codes: ["US", "CA"]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ============================================
// CLUB CLAIMS (for unclaimed clubs)
// ============================================

model ClubClaim {
  id            String   @id @default(uuid())

  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  status        ClaimStatus @default(PENDING)

  // Verification
  verificationCode  String?  // 6-digit code sent to club email
  verificationSentAt DateTime?
  verifiedAt    DateTime?

  message       String?  @db.Text // Optional message from claimant

  reviewedById  String?  // Admin who approved/rejected
  reviewNote    String?  @db.Text
  reviewedAt    DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, userId]) // One claim per user per club
  @@index([tenantId])
  @@index([userId])
  @@index([status])
}

enum ClaimStatus {
  PENDING
  EMAIL_SENT
  EMAIL_VERIFIED
  APPROVED
  REJECTED
}
